---
// PsInfoAppShell — the UNIFIED app shell for Puget Sound Info.
//
// bcn-lego-checked: the interactive controls compose legos — esa-icon for every
// glyph, esa-entity-search (the omnibox Lit component) for the cross-module
// search, esa-breadcrumbs for the in-content location trail. The topbar +
// collapsible grouped sidenav themselves are LAYOUT chrome, ported from the
// Beacon AppShell pattern Andy named ("make something like Beacon's
// sidebar/topbar"); the collapsed-rail flyout is a faithful port of Beacon's
// side-nav-modern flyout-menu. esa-app-shell was checked first and can't
// pre-expand the active module's children on load — a requirement for a buy-in
// walkthrough — so this ports the richer Beacon frame instead. No UI primitive
// is hand-rolled.
//
// The design problem this solves: today the five apps live on five subdomains
// with no shared nav; they connect only through a repeated "Explore" mega-menu.
// Here all five are peers in ONE persistent rail, the active module expands to
// its pages, and the topbar carries a search that spans all five at once.
import BaseLayout from './BaseLayout.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import EsaBreadcrumbs from '@esa/ecology/esa-breadcrumbs.astro';
import { navFor, MODULES, SEARCH_INDEX, ICONS, type ActiveNav } from '../data/psinfo-nav';
import { withBase } from '../lib/base';

interface Props {
  title?: string;
  active: ActiveNav;
}
const { title = 'Puget Sound Info', active } = Astro.props;

const sections = navFor(active);
const activeModule = MODULES.find((m) => m.id === active.moduleId);
const moduleLabel = activeModule?.label ?? 'Puget Sound Info';
const activeLeaf = activeModule?.pages.find((p) => p.id === active.leafId);

// Location trail — lives in the CONTENT, not the topbar. The front door (home,
// the leafless overview surface) carries no trail; every other page reads
// root / module / page.
const isHome = active.moduleId === 'overview' && !active.leafId;
const crumbs = [
  { label: 'Puget Sound Info', href: withBase('/prototypes/home') },
  { label: moduleLabel },
  ...(activeLeaf ? [{ label: activeLeaf.label }] : []),
];

// esa-entity-search wants entities + scopes; adapt the flat cross-module index.
const searchScopes = [...new Set(SEARCH_INDEX.map((e) => e.category))].map((c) => ({ id: c, label: c }));
const searchEntities = SEARCH_INDEX.map((e, i) => ({
  id: `e-${i}`,
  title: e.title,
  subtitle: e.subtitle,
  scope: e.category,
  url: e.route ? withBase(e.route) : '#',
}));
const searchPayload = JSON.stringify({ entities: searchEntities, scopes: searchScopes });
---

<BaseLayout title={title}>
  <a class="skip-link" href="#main-content">Skip to main content</a>
  <div class="shell">
    <!-- ═══ TOPBAR ═══ -->
    <header class="topbar">
      <div class="topbar__left">
        <button type="button" class="icon-toggle" id="sidebar-toggle" aria-label="Collapse sidebar" aria-expanded="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" class="icon-toggle__glyph"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/></svg>
        </button>
      </div>

      <div class="topbar__center">
        <button type="button" class="omnibox" id="omnibox-trigger" aria-label="Search across all of Puget Sound Info">
          <EsaIcon name="search" size="sm" paths={ICONS.search} />
          <span class="omnibox__label">Search indicators, strategies, activities…</span>
          <kbd class="omnibox__kbd">/</kbd>
        </button>
      </div>

      <div class="topbar__right">
        <a class="account" href="#account" aria-label="Account">
          <EsaIcon name="circle-user" size="md" paths={ICONS['circle-user']} />
        </a>
      </div>
    </header>

    <!-- ═══ BODY ═══ -->
    <div class="shell__body">
      <!-- ─── sidenav ─── -->
      <nav class="rail" id="rail" aria-label="Modules">
        <a class="brand" href={withBase('/prototypes/home')} aria-label="Puget Sound Info home">
          <img class="brand__mark" src={withBase('/psp-mark.png')} alt="" width="40" height="40" />
        </a>

        <div class="rail__nav">
          {sections.map((section) => (
            <div class:list={['navsec', { 'navsec--collapsed': !section.active, 'navsec--active': section.active }]}>
              <button type="button" class="navsec__head" aria-expanded={section.active ? 'true' : 'false'}>
                <EsaIcon name={section.id} size="sm" paths={section.icon} />
                <span class="navsec__title">{section.label}</span>
                <EsaIcon name="chevron-down" size="sm" paths={ICONS['chevron-down']} />
              </button>
              <ul class="navsec__items">
                {section.children.map((leaf) => (
                  <li>
                    {leaf.href ? (
                      <a href={leaf.href} class:list={['leaf', { 'leaf--active': leaf.active }]} aria-current={leaf.active ? 'page' : undefined}>
                        {leaf.label}
                      </a>
                    ) : (
                      <span class="leaf leaf--stub" title="Not part of this prototype">{leaf.label}</span>
                    )}
                  </li>
                ))}
              </ul>

              <!-- Collapsed-rail flyout (Beacon side-nav-modern port): hover the
                   module icon and its pages fly out beside the rail. -->
              <div class="flyout" role="menu" aria-label={section.label}>
                <div class="flyout__header">{section.label}</div>
                <ul class="flyout__items">
                  {section.children.map((leaf) => (
                    <li>
                      {leaf.href ? (
                        <a href={leaf.href} class:list={['flyout__link', { 'flyout__link--active': leaf.active }]}>{leaf.label}</a>
                      ) : (
                        <span class="flyout__link flyout__link--stub" title="Not part of this prototype">{leaf.label}</span>
                      )}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          ))}
        </div>

        <a class="rail__support" href="#request-support">
          <EsaIcon name="life-buoy" size="sm" paths={ICONS['life-buoy']} />
          <span>Request Support</span>
        </a>
      </nav>

      <!-- ─── content ─── -->
      <main class="content" id="main-content" tabindex="-1">
        {!isHome && (
          <div class="center content__crumbs">
            <EsaBreadcrumbs items={crumbs} />
          </div>
        )}
        <slot />
      </main>
    </div>
  </div>

  <esa-entity-search id="omnibox" placeholder="Search across Goals, Plans, Implementation & Funding, and Progress" hotkey="slash"></esa-entity-search>
  <script type="application/json" id="omnibox-data" set:html={searchPayload}></script>
</BaseLayout>

<script>
  import '@esa/ecology/esa-entity-search';

  const rail = document.getElementById('rail');
  const isCollapsed = () => !!rail?.classList.contains('rail--collapsed');

  // ── Collapsed-rail flyout (Beacon side-nav-modern behavior) ──────────────
  let closeTimer: number | null = null;
  const cancelClose = () => { if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; } };
  const closeFlyouts = () => document.querySelectorAll('.flyout--open').forEach((f) => f.classList.remove('flyout--open'));
  const scheduleClose = () => { cancelClose(); closeTimer = window.setTimeout(closeFlyouts, 150); };

  document.querySelectorAll<HTMLElement>('.navsec').forEach((sec) => {
    const head = sec.querySelector<HTMLButtonElement>('.navsec__head');
    const fly = sec.querySelector<HTMLElement>('.flyout');
    if (!head || !fly) return;

    const openFlyout = () => {
      cancelClose();
      closeFlyouts();
      fly.classList.add('flyout--open');
      // Anchor to the module row; clamp so it never runs off the viewport.
      const top = head.getBoundingClientRect().top;
      fly.style.top = `${Math.min(top, window.innerHeight - fly.offsetHeight - 8)}px`;
    };

    head.addEventListener('mouseenter', () => { if (isCollapsed()) openFlyout(); });
    head.addEventListener('click', () => {
      if (isCollapsed()) {
        fly.classList.contains('flyout--open') ? closeFlyouts() : openFlyout();
        return;
      }
      // Expanded rail: plain accordion toggle (any number open).
      const nowCollapsed = sec.classList.toggle('navsec--collapsed');
      head.setAttribute('aria-expanded', String(!nowCollapsed));
    });
    sec.addEventListener('mouseleave', () => { if (isCollapsed()) scheduleClose(); });
    fly.addEventListener('mouseenter', cancelClose);
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeFlyouts(); });

  // ── Sidebar collapse ──────────────────────────────────────────────────────
  const toggle = document.getElementById('sidebar-toggle');
  if (toggle && rail) {
    toggle.addEventListener('click', () => {
      const collapsed = rail.classList.toggle('rail--collapsed');
      closeFlyouts();
      toggle.classList.toggle('icon-toggle--collapsed', collapsed);
      toggle.setAttribute('aria-expanded', String(!collapsed));
      toggle.setAttribute('aria-label', collapsed ? 'Expand sidebar' : 'Collapse sidebar');
    });
  }

  // ── Cross-module omnibox ──────────────────────────────────────────────────
  const panel = document.getElementById('omnibox') as (HTMLElement & Record<string, unknown>) | null;
  const dataEl = document.getElementById('omnibox-data');
  const trigger = document.getElementById('omnibox-trigger');
  if (panel && dataEl) {
    const cfg = JSON.parse(dataEl.textContent || '{}');
    panel.entities = cfg.entities || [];
    panel.scopes = cfg.scopes || [];
    panel.addEventListener('select', (ev) => {
      const url = (ev as CustomEvent<{ entity?: { url?: string } }>).detail?.entity?.url;
      if (url && url !== '#') window.location.href = url;
    });
  }
  trigger?.addEventListener('click', () => (panel as (HTMLElement & { show?: () => void }) | null)?.show?.());
</script>

<style>
  .shell { display: flex; flex-direction: column; height: 100vh; }

  /* Visible only on keyboard focus — first tab stop on every page. */
  .skip-link {
    position: fixed; top: var(--spacing-200); left: var(--spacing-200); z-index: 2000;
    padding: var(--spacing-250) var(--spacing-400);
    background: var(--color-primary); color: #ffffff;
    border-radius: var(--radius-100);
    font-weight: var(--font-weight-semibold);
    transform: translateY(calc(-100% - var(--spacing-400)));
  }
  .skip-link:focus-visible {
    transform: none;
    outline: 2px solid var(--focus-ring-color); outline-offset: 2px;
  }

  /* ═══ TOPBAR ═══ */
  .topbar {
    position: fixed; inset: 0 0 auto 0; height: 56px; z-index: 1100;
    display: grid; grid-template-columns: auto 1fr auto; align-items: center;
    gap: var(--spacing-400);
    padding: 0 var(--spacing-400);
    background: var(--ps-info-bar-bg);
    border-bottom: 1px solid var(--color-border-strong);
  }
  .topbar__left { display: flex; align-items: center; gap: var(--spacing-300); min-width: 0; }
  .topbar__center { display: flex; justify-content: center; min-width: 0; }
  .topbar__right { display: flex; align-items: center; justify-content: flex-end; gap: var(--spacing-300); }

  .icon-toggle {
    display: inline-flex; align-items: center; justify-content: center;
    width: 34px; height: 34px; border-radius: var(--radius-100);
    color: var(--color-text-tertiary); transition: background 150ms ease, color 150ms ease;
  }
  .icon-toggle:hover { background: color-mix(in srgb, var(--color-primary) 8%, transparent); color: var(--color-primary); }
  .icon-toggle:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .icon-toggle__glyph { transition: transform 150ms ease; }
  .icon-toggle--collapsed .icon-toggle__glyph { transform: scaleX(-1); }

  .omnibox {
    display: inline-flex; align-items: center; gap: var(--spacing-200);
    width: clamp(240px, 42vw, 520px); height: 38px; padding: 0 var(--spacing-300);
    border: 1px solid var(--color-border-strong); border-radius: var(--radius-100);
    background: var(--color-surface); color: var(--color-text-muted);
    font-size: var(--ps-info-text-meta-lg); transition: border-color 150ms ease, box-shadow 150ms ease;
  }
  .omnibox:hover { border-color: var(--color-secondary); }
  .omnibox:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .omnibox :global(.esa-icon) { color: var(--color-text-muted); flex: none; }
  .omnibox__label { flex: 1; text-align: left; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .omnibox__kbd {
    flex: none; display: inline-flex; align-items: center; justify-content: center;
    min-width: 20px; height: 20px; padding: 0 6px;
    border: 1px solid var(--color-border-strong); border-radius: var(--radius-100);
    background: var(--color-surface-sunken); font-family: var(--font-mono); font-size: var(--ps-info-text-meta);
    color: var(--color-text-tertiary);
  }

  .account {
    display: inline-flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: var(--radius-full); color: var(--color-text-tertiary);
    transition: background 150ms ease, color 150ms ease;
  }
  .account:hover { background: color-mix(in srgb, var(--color-primary) 8%, transparent); color: var(--color-primary); }

  /* ═══ BODY ═══ */
  .shell__body { display: flex; flex: 1; overflow: hidden; padding-top: 56px; }

  /* ═══ SIDENAV ═══ */
  .rail {
    width: 276px; flex-shrink: 0; height: 100%;
    display: flex; flex-direction: column;
    background: var(--ps-info-rail-bg);
    border-right: 1px solid var(--color-border);
    transition: width 200ms ease-in-out;
    overflow: hidden;
  }
  .rail--collapsed { width: 72px; }

  .brand {
    display: flex; align-items: center;
    margin: var(--spacing-300) var(--spacing-300) var(--spacing-200);
    padding: var(--spacing-250) var(--spacing-250);
    border-radius: var(--radius-100);
    text-decoration: none;
    transition: background 150ms ease;
  }
  .brand:hover { background: color-mix(in srgb, var(--color-primary) 6%, transparent); }
  .brand__mark { display: block; width: 40px; height: 40px; flex: none; transition: width 200ms ease-in-out, height 200ms ease-in-out; }
  .rail--collapsed .brand { justify-content: center; margin-inline: var(--spacing-200); padding: var(--spacing-200) 0; }
  .rail--collapsed .brand__mark { width: 28px; height: 28px; }

  .rail__nav {
    flex: 1; overflow-y: auto; overflow-x: hidden;
    padding: var(--spacing-200) var(--spacing-300);
    display: flex; flex-direction: column; gap: var(--spacing-050);
    scrollbar-width: thin;
  }

  .navsec { display: flex; flex-direction: column; }
  /* Each of the five modules is its own program — a hairline keeps them from
     collapsing into one undifferentiated list. */
  .navsec + .navsec { margin-top: var(--spacing-200); padding-top: var(--spacing-200); border-top: 1px solid var(--color-border); }

  .navsec__head {
    display: flex; align-items: center; gap: var(--spacing-300);
    width: 100%; text-align: left;
    padding: var(--spacing-250) var(--spacing-250);
    border-radius: var(--radius-100);
    font-size: 0.9375rem; font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    transition: background 150ms ease, color 150ms ease;
  }
  .navsec__head:hover { background: color-mix(in srgb, var(--color-primary) 7%, transparent); }
  .navsec__head:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .navsec__head > :global(.esa-icon:first-child) { flex: none; color: var(--color-text-tertiary); }
  .navsec__title { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  /* The chevron is the head's LAST esa-icon (esa-icon drops a class prop, so
     it must be selected structurally). */
  .navsec__head > :global(.esa-icon:last-child) { flex: none; color: var(--color-text-muted); transition: transform 150ms ease; }
  .navsec--collapsed .navsec__head > :global(.esa-icon:last-child) { transform: rotate(-90deg); }
  /* Active module: brand-blue title on a blue wash; the accent-orange icon is
     the one identity moment in the rail. */
  .navsec--active > .navsec__head { color: var(--color-primary); }
  .navsec--active > .navsec__head > :global(.esa-icon:first-child) { color: var(--color-secondary); }

  .navsec__items {
    list-style: none; margin: 0; padding: var(--spacing-050) 0 var(--spacing-100);
    display: flex; flex-direction: column; gap: 1px;
    max-height: 500px; opacity: 1; overflow: hidden;
    transition: max-height 200ms ease-in-out, opacity 150ms ease-in-out;
  }
  .navsec--collapsed .navsec__items { max-height: 0; opacity: 0; padding: 0; }
  .rail--collapsed .navsec__items { display: none; }
  .rail--collapsed .navsec__title,
  .rail--collapsed .navsec__head > :global(.esa-icon:last-child) { display: none; }
  .rail--collapsed .navsec__head { justify-content: center; }

  .leaf {
    display: block; padding: var(--spacing-200) var(--spacing-250) var(--spacing-200) 2.75rem;
    border-radius: var(--radius-100);
    font-size: var(--ps-info-text-meta-lg); color: var(--color-text-secondary);
    text-decoration: none; line-height: 1.3;
    transition: background 150ms ease, color 150ms ease;
  }
  .leaf:hover { background: color-mix(in srgb, var(--color-primary) 7%, transparent); color: var(--color-primary); }
  .leaf--active { background: var(--color-surface); color: var(--color-primary); font-weight: var(--font-weight-semibold); box-shadow: inset 0 0 0 1px var(--color-primary-border); }
  .leaf--stub { color: var(--color-text-muted); cursor: default; }
  .leaf--stub:hover { background: transparent; color: var(--color-text-muted); }

  /* ── Collapsed-rail flyout ── */
  .flyout {
    display: none;
    position: fixed; left: 76px; min-width: 220px; z-index: 1200;
    background: var(--color-surface);
    border: 1px solid var(--color-border); border-radius: var(--radius-100);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
  }
  .flyout--open { display: block; animation: flyout-in 150ms ease-out; }
  @keyframes flyout-in {
    from { opacity: 0; transform: translateX(-8px); }
    to { opacity: 1; transform: translateX(0); }
  }
  .flyout__header {
    padding: var(--spacing-300) var(--spacing-400);
    font-size: var(--ps-info-text-meta-lg); font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
    border-bottom: 1px solid var(--color-border);
  }
  .flyout__items { list-style: none; margin: 0; padding: var(--spacing-200) 0; }
  .flyout__link {
    display: block; padding: var(--spacing-200) var(--spacing-400);
    font-size: var(--ps-info-text-meta-lg); color: var(--color-text-secondary);
    text-decoration: none; white-space: nowrap;
    transition: background 150ms ease, color 150ms ease;
  }
  .flyout__link:hover { background: color-mix(in srgb, var(--color-primary) 7%, transparent); color: var(--color-primary); }
  .flyout__link--active { color: var(--color-primary); font-weight: var(--font-weight-semibold); background: var(--color-primary-subtle); }
  .flyout__link--stub { color: var(--color-text-muted); cursor: default; }
  .flyout__link--stub:hover { background: transparent; color: var(--color-text-muted); }

  .rail__support {
    flex: none; display: flex; align-items: center; gap: var(--spacing-250);
    margin: var(--spacing-200) var(--spacing-300) var(--spacing-300);
    padding: var(--spacing-250) var(--spacing-300);
    border-radius: var(--radius-100); border: 1px solid var(--color-border);
    background: var(--color-surface);
    font-size: var(--ps-info-text-meta-lg); font-weight: var(--font-weight-medium); color: var(--color-text-secondary);
    transition: border-color 150ms ease, color 150ms ease;
  }
  .rail__support:hover { border-color: var(--color-secondary); color: var(--color-primary); }
  .rail__support :global(.esa-icon) { color: var(--color-text-muted); flex: none; }
  .rail--collapsed .rail__support { justify-content: center; }
  .rail--collapsed .rail__support span { display: none; }

  /* ═══ CONTENT ═══ */
  .content { flex: 1; overflow-y: auto; min-width: 0; background: var(--color-background); padding: var(--spacing-500) var(--spacing-600) var(--spacing-800); scroll-behavior: smooth; }
  .content:focus-visible { outline: none; }
  @media (prefers-reduced-motion: reduce) { .content { scroll-behavior: auto; } }
  .content__crumbs { margin-bottom: var(--spacing-400); }
  @media (max-width: 720px) { .content { padding: var(--spacing-400) var(--spacing-400) var(--spacing-700); } }

  @media (max-width: 720px) {
    .omnibox__label, .omnibox__kbd { display: none; }
    .omnibox { width: 44px; padding: 0; justify-content: center; }
    .rail { position: fixed; z-index: 1050; box-shadow: 0 8px 32px rgba(0,0,0,0.16); }
  }
</style>
