---
// Puget Sound Info base layout — wires the hub tokens + the Puget Sound Info theme,
// loads the brand's fonts, and sets data-theme="ps-info" so every
// inherited esa-* component re-skins to Puget Sound Info.
import '@esa/tokens/tokens.css';
import '@esa/tokens/component-tokens.css';
import '@esa/tokens/type-roles.css';
import '@esa/tokens/layouts.css';
import '../styles/theme-ps-info.css';
// Runtime handoff inspector — self-gating: dormant unless the current route
// has a bundle at public/handoff/<slug>/ (generated via `npx handoff`).
import HandoffInspector from '@esa/handoff/HandoffInspector.astro';

interface Props {
  title?: string;
}
const { title = 'Puget Sound Info' } = Astro.props;
---
<!doctype html>
<html lang="en" data-theme="ps-info">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* Anthropic faces are self-hosted (public/fonts/) and declared @font-face in
        theme-ps-info.css — no external font <link> needed. */}
    <link rel="preload" href="/fonts/AnthropicSans-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/AnthropicSerif-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <title>{title}</title>
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: var(--font-sans, system-ui, sans-serif);
        font-weight: var(--font-weight-regular, 350);
        color: var(--color-text-primary, #3d3d3d);
        background: var(--color-surface, #fff);
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--color-text-link, #43608a); text-decoration: none; }
      img { display: block; max-width: 100%; }
      button { font-family: inherit; cursor: pointer; background: none; border: 0; }
    </style>
  </head>
  <body>
    <slot />
    <HandoffInspector />
  </body>
</html>
