---
// Data Center — the platform's data repository hub (pugetsoundinfo.wa.gov/
// DataCenter). Content is exact: one intro sentence, a 3x3 grid of 9 active
// resource tiles, and one archived tile under an "Archived" heading. No tile
// carries body copy in source (every sectionDetails span is empty), so tiles
// resolve to icon + title only. Two tiles route into this prototype's own
// pages (Indicators, Web Services); the rest point at the live admin/list
// tools this demo does not rebuild.
import PsInfoAppShell from '../../layouts/PsInfoAppShell.astro';
import PsInfoPhotoHeader from '../../components/psinfo/PsInfoPhotoHeader.astro';
import PsInfoSectionTitle from '../../components/psinfo/PsInfoSectionTitle.astro';
import PsInfoDataCenterGrid from '../../components/psinfo/PsInfoDataCenterGrid.astro';
import {
  DATA_CENTER_HERO,
  DATA_CENTER_RESOURCES,
  DATA_CENTER_ARCHIVED_HEADING,
  DATA_CENTER_ARCHIVED,
} from '../../data/pages/data-center';
---
<!-- manifest:
  layout: PsInfoAppShell (active Overview/Data Center) > center+stack spine
  sections:
    - page header       -> psinfo-photo-header (band)
    - active resources   -> psinfo-data-center-grid
    - archived resource  -> psinfo-section-title + psinfo-data-center-grid
-->
<PsInfoAppShell title="Data Center — Puget Sound Info" active={{ moduleId: 'overview', leafId: 'data-center' }}>
  <div class="center stack" data-gap="xl">
    <PsInfoPhotoHeader
      size="band"
      image="/photos/sound-aerial.jpg"
      focus="50% 60%"
      title={DATA_CENTER_HERO.title}
      lede={DATA_CENTER_HERO.lede}
    />

    <PsInfoDataCenterGrid items={DATA_CENTER_RESOURCES} />

    <div class="stack" data-gap="md">
      <PsInfoSectionTitle title={DATA_CENTER_ARCHIVED_HEADING} />
      <PsInfoDataCenterGrid items={DATA_CENTER_ARCHIVED} />
    </div>
  </div>
</PsInfoAppShell>
