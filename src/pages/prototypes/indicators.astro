---
// Indicators — the Progress module's measurement system: 86 indicators (70
// Vital Sign Indicators + 16 Progress Indicators). The listing renders as the
// source page's own ag-grid (ag-grid-community) — one grid, every row, with
// the source's sortable/filterable columns and toolbar. Rows link to their
// real detail pages on pugetsoundinfo.wa.gov (internal destinations — no
// external marks); the exemplar row (id 32, "Number of Southern Resident
// killer whales") routes internally to the built prototype detail page —
// every other row links out to its real detail page (this prototype hasn't
// built the other 85 detail pages).
//
// RE-AUDITED 2026-07-23 against the live www page (https://www.pugetsoundinfo
// .wa.gov/Indicator/Index — source of truth per revision direction; the
// 2026-07-22 QA audit had folded in QA-only regressions, now reversed).
// Sections, source order: page header (photo band, title "Puget Sound
// Indicators", lede = intro P1) -> intro definitions prose (P2-P4 verbatim,
// psinfo-indicators-definitions) -> portal cards (psinfo-indicators-portals)
// -> indicator grid (psinfo-indicators-grid, shared .psinfo-agrid dark-header
// skin). See src/data/contracts/indicators.md.
import PsInfoAppShell from '../../layouts/PsInfoAppShell.astro';
import PsInfoPhotoHeader from '../../components/psinfo/PsInfoPhotoHeader.astro';
import PsInfoIndicatorsDefinitions from '../../components/psinfo/PsInfoIndicatorsDefinitions.astro';
import PsInfoIndicatorsPortals from '../../components/psinfo/PsInfoIndicatorsPortals.astro';
import PsInfoIndicatorsGrid from '../../components/psinfo/PsInfoIndicatorsGrid.astro';
import {
  PAGE_TITLE,
  INTRO_PARAGRAPH,
  INDICATOR_TYPE_DEFINITIONS,
  CLOSING_PARAGRAPH,
  PORTALS,
} from '../../data/pages/indicators';
---
<!-- manifest:
  layout: PsInfoAppShell (active Progress > Indicators) > center+stack spine
  sections:
    - page header             -> psinfo-photo-header (photo band, composes esa-page-header)
    - indicator type defs     -> psinfo-indicators-definitions
    - portal cards            -> psinfo-indicators-portals (source psiButtonCards: program logo + title + blurb)
    - indicator grid          -> psinfo-indicators-grid (ag-grid-community, one grid, all 86 rows, prod toolbar)
-->
<PsInfoAppShell title={`${PAGE_TITLE} — Puget Sound Info`} active={{ moduleId: 'progress', leafId: 'indicators' }}>
  <div class="center stack" data-gap="xl">
    <PsInfoPhotoHeader
      size="band"
      image="/photos/indicators/puget-sound-indicators-salmon-banner.jpg"
      focus="50% 55%"
      title={PAGE_TITLE}
      lede={INTRO_PARAGRAPH}
    />

    <PsInfoIndicatorsDefinitions definitions={INDICATOR_TYPE_DEFINITIONS} closing={CLOSING_PARAGRAPH} />

    <PsInfoIndicatorsPortals portals={PORTALS} />

    <PsInfoIndicatorsGrid />
  </div>
</PsInfoAppShell>
