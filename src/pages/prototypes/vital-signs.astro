---
// Vital Signs — the flagship front door of the Vital Signs sub-site
// (vitalsigns.pugetsoundinfo.wa.gov). The live home page is exactly three
// sections: the Vital Signs wheel (a flat PNG + image map on the source,
// rebuilt natively here — every tile a live link), an un-headed
// three-paragraph intro block, and the Contributing Partners logo wall
// (the source's own logo files, standardized sizing). Content is verbatim
// (src/data/pages/vital-signs.ts, src/data/pages/vital-signs-module.ts).
import PsInfoAppShell from '../../layouts/PsInfoAppShell.astro';
import PsInfoPhotoHeader from '../../components/psinfo/PsInfoPhotoHeader.astro';
import PsInfoGoalsNav from '../../components/psinfo/PsInfoGoalsNav.astro';
import PsInfoVsWheel from '../../components/psinfo/PsInfoVsWheel.astro';
import PsInfoVitalSignsIntro from '../../components/psinfo/PsInfoVitalSignsIntro.astro';
import PsInfoVsPartners from '../../components/psinfo/PsInfoVsPartners.astro';
import { PAGE_TITLE, HERO, ESPANOL_LINK, INTRO_PARAGRAPHS } from '../../data/pages/vital-signs';
---
<!-- manifest:
  layout: PsInfoAppShell (active Goals) > center+stack spine
  sections:
    - page header            -> psinfo-photo-header (photo band) with psinfo-goals-nav
                                in its band slot (goal-tinted links + Vital Signs dropdowns —
                                the standard hero + band sub-nav pattern)
    - vital signs wheel      -> psinfo-vs-wheel (native rebuild of the source graphic)
    - intro text (un-headed) -> psinfo-vital-signs-intro
    - contributing partners  -> psinfo-vs-partners (real logo files)
-->
<PsInfoAppShell title={`${PAGE_TITLE} — Puget Sound Info`} active={{ moduleId: 'goals' }}>
  <div class="center stack" data-gap="2xl">
    <PsInfoPhotoHeader
      size="band"
      image={HERO.image}
      focus={HERO.focus}
      title={PAGE_TITLE}
    >
      <PsInfoGoalsNav slot="band" />
    </PsInfoPhotoHeader>

    <PsInfoVsWheel />

    <PsInfoVitalSignsIntro espanolLink={ESPANOL_LINK} paragraphs={INTRO_PARAGRAPHS} />

    <PsInfoVsPartners />
  </div>
</PsInfoAppShell>
