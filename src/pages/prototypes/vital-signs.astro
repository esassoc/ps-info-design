---
// Vital Signs — the flagship front door of the Vital Signs sub-site
// (vitalsigns.pugetsoundinfo.wa.gov). The live home page has no visible
// on-page heading (only <title>Vital Signs </title>) and exactly three
// sections: an interactive wheel grouping all 23 Vital Signs into the 5
// recovery goals (reproduced here as a readable list, real data from the
// Goals unit's own src/data/pages/goals.ts — verbatim-usable, unchanged),
// an un-headed three-paragraph intro block, and the "Contributing Partners"
// grid of 33 organizations. No stats, no per-goal counts, no indicator
// lists, no cross-link band — none of that appears on the source home page.
import PsInfoAppShell from '../../layouts/PsInfoAppShell.astro';
import PsInfoPhotoHeader from '../../components/psinfo/PsInfoPhotoHeader.astro';
import PsInfoVitalSignsGoalGroups from '../../components/psinfo/PsInfoVitalSignsGoalGroups.astro';
import PsInfoVitalSignsIntro from '../../components/psinfo/PsInfoVitalSignsIntro.astro';
import PsInfoSectionTitle from '../../components/psinfo/PsInfoSectionTitle.astro';
import PsInfoAboutNarrative from '../../components/psinfo/PsInfoAboutNarrative.astro';
import { GOALS } from '../../data/pages/goals';
import { PAGE_TITLE, HERO, ESPANOL_LINK, INTRO_PARAGRAPHS, CONTRIBUTING_PARTNERS } from '../../data/pages/vital-signs';
---
<!-- manifest:
  layout: PsInfoAppShell (active Goals) > center+stack spine
  sections:
    - page header            -> psinfo-photo-header (photo band)
    - vital signs wheel      -> psinfo-vital-signs-goal-groups
    - intro text (un-headed) -> psinfo-vital-signs-intro
    - contributing partners  -> psinfo-section-title + psinfo-about-narrative
-->
<PsInfoAppShell title={`${PAGE_TITLE} — Puget Sound Info`} active={{ moduleId: 'goals' }}>
  <div class="center stack" data-gap="xl">
    <PsInfoPhotoHeader
      size="band"
      image={HERO.image}
      focus={HERO.focus}
      title={PAGE_TITLE}
    />

    <PsInfoVitalSignsGoalGroups goals={GOALS} />

    <PsInfoVitalSignsIntro espanolLink={ESPANOL_LINK} paragraphs={INTRO_PARAGRAPHS} />

    <div class="stack" data-gap="md">
      <PsInfoSectionTitle title="Contributing Partners" />
      <PsInfoAboutNarrative blocks={[{ type: 'partners', partners: CONTRIBUTING_PARTNERS }]} />
    </div>
  </div>
</PsInfoAppShell>
