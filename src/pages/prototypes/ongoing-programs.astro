---
// Ongoing Programs — the Ongoing Programs Portal's Index page. Content is
// exact: the source's own title ("Ongoing Programs", no lede — the two intro
// paragraphs below are the page's own body copy, not a separate tagline),
// its inline regional map image, and its two verbatim intro paragraphs.
// Nothing else lives on this route in the source (see
// src/data/contracts/ongoing-programs.md): no headline stats, no program
// table, no cross-link band — those belong to a different route
// (/OngoingProgram/Programs) and endpoint, out of this contract's scope.
import PsInfoAppShell from '../../layouts/PsInfoAppShell.astro';
import EsaPageHeader from '@esa/ecology/esa-page-header.astro';
import PsInfoOngoingProgramsIntro from '../../components/psinfo/PsInfoOngoingProgramsIntro.astro';
import { PAGE_TITLE, INTRO_PARAGRAPHS, MAP_IMAGE } from '../../data/pages/ongoing-programs';
---
<!-- manifest:
  layout: PsInfoAppShell (active Implementation and Funding > Ongoing Programs Portal) > center+stack spine
  sections:
    - page header -> esa-page-header (plain, title only, no lede)
    - intro (map image + 2 paragraphs) -> psinfo-ongoing-programs-intro (composes esa-card)
-->
<PsInfoAppShell title={`${PAGE_TITLE} — Puget Sound Info`} active={{ moduleId: 'implementation', leafId: 'ongoing-programs' }}>
  <div class="center stack" data-gap="xl">
    <EsaPageHeader title={PAGE_TITLE} />

    <PsInfoOngoingProgramsIntro paragraphs={INTRO_PARAGRAPHS} image={MAP_IMAGE} />
  </div>
</PsInfoAppShell>
