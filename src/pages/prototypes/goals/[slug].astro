---
// Goals — the five statutory recovery goals, one dynamic template mirroring
// vitalsigns.pugetsoundinfo.wa.gov/VitalSignGoal/Detail/{1,2,3,7,6}, framed
// in the standard hero + band sub-nav pattern (home / Action Agenda / Vital
// Signs): the photo hero carries the goal's H1 and its source photograph,
// the band carries the five goal-tinted links with Vital Signs dropdowns
// (this goal current), then the goal's statement/narrative block, then the
// Fancytree of the goal's Vital Signs and indicators framed in the goal's
// ThemeColor with the source's own progress/target-status icons. All content
// is verbatim from the source (src/data/pages/goals.ts).
import PsInfoAppShell from '../../../layouts/PsInfoAppShell.astro';
import PsInfoPhotoHeader from '../../../components/psinfo/PsInfoPhotoHeader.astro';
import PsInfoGoalsNav from '../../../components/psinfo/PsInfoGoalsNav.astro';
import PsInfoVsGoalIntro from '../../../components/psinfo/PsInfoVsGoalIntro.astro';
import PsInfoVsFancyTree from '../../../components/psinfo/PsInfoVsFancyTree.astro';
import { GOALS, type GoalDetail } from '../../../data/pages/goals';

export function getStaticPaths() {
  return GOALS.map((goal) => ({ params: { slug: goal.slug }, props: { goal } }));
}

interface Props {
  goal: GoalDetail;
}
const { goal } = Astro.props;
---
<!-- manifest:
  layout: PsInfoAppShell (active Goals > this goal) > center+stack spine
  sections:
    - page header      -> psinfo-photo-header (goal photo, goal name H1) with
                          psinfo-goals-nav in its band slot (goal-tinted links +
                          Vital Signs dropdowns, this goal current)
    - goal statement   -> psinfo-vs-goal-intro (statement + narrative)
    - vital signs & indicators tree -> psinfo-vs-fancy-tree (goal-framed, prod icons)
-->
<PsInfoAppShell title={`${goal.name} — Puget Sound Info`} active={{ moduleId: 'goals', leafId: goal.navLeafId }}>
  <div class="center stack" data-gap="xl">
    <PsInfoPhotoHeader
      size="band"
      image={goal.image}
      title={goal.name}
    >
      <PsInfoGoalsNav slot="band" activeGoal={goal.slug} />
    </PsInfoPhotoHeader>

    <PsInfoVsGoalIntro statement={goal.statement} narrative={goal.narrative} />

    <PsInfoVsFancyTree goals={[goal]} frameHueVar={goal.hueVar} expandedLevels={1} treeId={`tree-${goal.slug}`} />
  </div>
</PsInfoAppShell>
