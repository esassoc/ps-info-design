---
// Goals — the five statutory recovery goals, one dynamic template mirroring
// vitalsigns.pugetsoundinfo.wa.gov/VitalSignGoal/Detail/{1,2,3,7,6}: the
// Vital Signs module sub-nav (color-coded goal columns with Vital Sign
// dropdowns), then the goal's title block in source order (colored uppercase
// name, bold statement, narrative, inline photo), then the Fancytree of the
// goal's Vital Signs and indicators framed in the goal's ThemeColor, with the
// source's own progress/target-status icons. All content is verbatim from the
// source (src/data/pages/goals.ts).
import PsInfoAppShell from '../../../layouts/PsInfoAppShell.astro';
import PsInfoVsSubnav from '../../../components/psinfo/PsInfoVsSubnav.astro';
import PsInfoVsGoalIntro from '../../../components/psinfo/PsInfoVsGoalIntro.astro';
import PsInfoVsFancyTree from '../../../components/psinfo/PsInfoVsFancyTree.astro';
import { GOALS, type GoalDetail } from '../../../data/pages/goals';

export function getStaticPaths() {
  return GOALS.map((goal) => ({ params: { slug: goal.slug }, props: { goal } }));
}

interface Props {
  goal: GoalDetail;
}
const { goal } = Astro.props;
---
<!-- manifest:
  layout: PsInfoAppShell (active Goals > this goal) > center+stack spine
  sections:
    - vital signs module nav -> psinfo-vs-subnav (banner + goal dropdowns + trail)
    - goal title block       -> psinfo-vs-goal-intro (name/statement/narrative/photo)
    - vital signs & indicators tree -> psinfo-vs-fancy-tree (goal-framed, prod icons)
-->
<PsInfoAppShell title={`${goal.name} — Puget Sound Info`} active={{ moduleId: 'goals', leafId: goal.navLeafId }}>
  <div class="center stack" data-gap="xl">
    <PsInfoVsSubnav activeGoal={goal.slug} />

    <PsInfoVsGoalIntro
      name={goal.name}
      statement={goal.statement}
      narrative={goal.narrative}
      image={goal.image}
      imageAlt={goal.imageAlt}
      hueVar={goal.hueVar}
    />

    <PsInfoVsFancyTree goals={[goal]} frameHueVar={goal.hueVar} expandedLevels={1} treeId={`tree-${goal.slug}`} />
  </div>
</PsInfoAppShell>
