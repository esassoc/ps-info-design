---
// NEP Atlas — the module HOME page, one of six pages in this lane (see
// src/data/contracts/nep-atlas.md for the full URL list). Prod's home page
// server-rendered HTML is genuinely short — one welcome block, one map
// block, one funders line — reproduced here in full, PLUS the module's own
// nav bar riding the photo header's band slot. Sub-pages (About, NEP Activity
// Map, NEP Activities, NEP Awards, NEP Investment Summaries) live under
// /prototypes/nep-atlas/*. Prod mounts an interactive Leaflet "Activities"
// map inline on the home page (a projectLocationsMapInitJson blob carrying
// 1,614 GeoJSON point features); this build reproduces the map's presence
// and interaction with INVENTED representative points. See
// src/data/contracts/nep-atlas.md and src/data/pages/nep-atlas.ts for full
// sourcing notes and provenance.
import PsInfoAppShell from '../../layouts/PsInfoAppShell.astro';
import PsInfoPhotoHeader from '../../components/psinfo/PsInfoPhotoHeader.astro';
import PsInfoSectionTitle from '../../components/psinfo/PsInfoSectionTitle.astro';
import PsInfoNepAtlasNav from '../../components/psinfo/PsInfoNepAtlasNav.astro';
import PsInfoNepAtlasNarrative from '../../components/psinfo/PsInfoNepAtlasNarrative.astro';
import PsInfoNepAtlasMap from '../../components/psinfo/PsInfoNepAtlasMap.astro';
import {
  HERO_TITLE, PAGE_LEDE,
  WELCOME_PARAGRAPH, WELCOME_PHOTO,
  FUNDERS_PARAGRAPH,
} from '../../data/pages/nep-atlas';
---
<!-- manifest:
  layout: PsInfoAppShell (active Implementation and Funding > NEP Atlas) > center+stack spine
  sections:
    - page header + band nav -> psinfo-photo-header (photo band; hero = the source's own welcome photo) + psinfo-nep-atlas-nav (module bar, no cell current — prod's bar has no Home item)
    - welcome                -> psinfo-section-title + psinfo-nep-atlas-narrative (verbatim paragraph)
    - activities map          -> psinfo-nep-atlas-map (interactive Leaflet reproduction; invented representative points; verbatim "Click to view the full map" link, now internal to /prototypes/nep-atlas/map)
    - funding provided by     -> psinfo-section-title + psinfo-nep-atlas-narrative (pipe-separated funder links)
-->
<PsInfoAppShell title="NEP Atlas — Puget Sound Info" active={{ moduleId: 'implementation', leafId: 'nep-atlas' }}>
  <div class="center stack" data-gap="xl">
    <PsInfoPhotoHeader
      size="band"
      image={WELCOME_PHOTO.image}
      focus="50% 35%"
      title={HERO_TITLE}
      lede={PAGE_LEDE}
    >
      <PsInfoNepAtlasNav slot="band" />
    </PsInfoPhotoHeader>

    <div class="stack" data-gap="md" id="welcome">
      <PsInfoSectionTitle title="Welcome to the NEP Atlas" />
      <PsInfoNepAtlasNarrative paragraphs={[WELCOME_PARAGRAPH]} />
    </div>

    <div class="stack" data-gap="md" id="map">
      <PsInfoNepAtlasMap />
    </div>

    <div class="stack" data-gap="md" id="funding">
      <PsInfoSectionTitle title="Funding provided by" />
      <PsInfoNepAtlasNarrative paragraphs={[FUNDERS_PARAGRAPH]} />
    </div>
  </div>
</PsInfoAppShell>
