---
// NEP Atlas — a directed reproduction of a SINGLE URL:
// https://nepatlas.pugetsoundinfo.wa.gov/ (the NEP Atlas mini-site's home
// page only, fetched 2026-07-17). The home page's server-rendered HTML is
// genuinely short — one welcome block, one map teaser, one funders line —
// and that is the entire content of this page; nothing is invented and
// nothing from the mini-site's other pages (About, Activity Index, Award
// Index, Activity Summary) is in scope. See
// src/data/contracts/nep-atlas.md and src/data/pages/nep-atlas.ts for full
// sourcing notes and the documented gap (the map is a client-side-only
// Leaflet mount with zero server-rendered content).
import PsInfoAppShell from '../../layouts/PsInfoAppShell.astro';
import PsInfoPhotoHeader from '../../components/psinfo/PsInfoPhotoHeader.astro';
import PsInfoSectionTitle from '../../components/psinfo/PsInfoSectionTitle.astro';
import PsInfoNepAtlasNarrative from '../../components/psinfo/PsInfoNepAtlasNarrative.astro';
import EsaCard from '@esa/ecology/esa-card.astro';
import EsaButton from '@esa/ecology/esa-button.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import {
  PAGE_EYEBROW, PAGE_TITLE, PAGE_LEDE,
  WELCOME_PARAGRAPH, WELCOME_PHOTO,
  MAP_TEASER,
  FUNDERS_PARAGRAPH,
} from '../../data/pages/nep-atlas';

const ARROW = '<path d="M7 7h10v10"/><path d="M7 17 17 7"/>';
---
<!-- manifest:
  layout: PsInfoAppShell (active Implementation and Funding > NEP Atlas) > center+stack spine
  sections:
    - page header       -> psinfo-photo-header (photo band; hero = the source's own welcome photo)
    - welcome            -> psinfo-section-title + psinfo-nep-atlas-narrative (verbatim paragraph)
    - map teaser         -> esa-card + esa-button (link out; source's map mount is client-side-only, see data file gaps)
    - funding provided by -> psinfo-section-title + psinfo-nep-atlas-narrative (pipe-separated funder links)
-->
<PsInfoAppShell title="NEP Atlas — Puget Sound Info" active={{ moduleId: 'implementation', leafId: 'nep-atlas' }}>
  <div class="center stack" data-gap="xl">
    <PsInfoPhotoHeader
      size="band"
      image={WELCOME_PHOTO.image}
      focus="50% 35%"
      eyebrow={PAGE_EYEBROW}
      title={PAGE_TITLE}
      lede={PAGE_LEDE}
    />

    <div class="stack" data-gap="md" id="welcome">
      <PsInfoSectionTitle title="Welcome to the NEP Atlas" />
      <PsInfoNepAtlasNarrative paragraphs={[WELCOME_PARAGRAPH]} />
    </div>

    <div class="stack" data-gap="md" id="map">
      <EsaCard variant="outlined">
        <div class="stack" data-align="center" data-gap="sm">
          <EsaButton href={MAP_TEASER.href} target="_blank" rel="noopener" size="lg">
            {MAP_TEASER.linkText}
            <EsaIcon name="arrow-up-right" size="xs" paths={ARROW} />
          </EsaButton>
        </div>
      </EsaCard>
    </div>

    <div class="stack" data-gap="md" id="funding">
      <PsInfoSectionTitle title="Funding provided by" />
      <PsInfoNepAtlasNarrative paragraphs={[FUNDERS_PARAGRAPH]} />
    </div>
  </div>
</PsInfoAppShell>
