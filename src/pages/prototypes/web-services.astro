---
// Web Services — the Overview module's data-endpoint reference. Content is
// EXACT: sourced 2026-07-17 from https://www.pugetsoundinfo.wa.gov/WebServices/Index,
// a flat, alphabetically-ordered list of 28 real download endpoints (Action
// Agenda outcomes/strategies, Funds, NEP activity/expenditure/funding/award
// records, Ongoing Programs, Progress Indicators, Puget Sound Indicators,
// Vital Signs). The source page carries no imagery beyond site chrome, so
// per contract this unit's header treatment is plain (esa-page-header), not
// a photo band.
import PsInfoAppShell from '../../layouts/PsInfoAppShell.astro';
import EsaPageHeader from '@esa/ecology/esa-page-header.astro';
import PsInfoWebServicesCatalog from '../../components/psinfo/PsInfoWebServicesCatalog.astro';
import { PAGE_TITLE, INTRO_PARAGRAPH, WEB_SERVICES } from '../../data/pages/web-services';
---
<!-- manifest:
  layout: PsInfoAppShell (active Overview > Web Services) > center+stack spine
  sections:
    - page header       -> esa-page-header (plain, no photo band; lede = source intro paragraph)
    - services catalog  -> psinfo-web-services-catalog (28 endpoints in source order, one esa-collapsible each; no section heading — prod runs entries directly after the intro)
-->
<PsInfoAppShell title={`${PAGE_TITLE} — Puget Sound Info`} active={{ moduleId: 'overview', leafId: 'web-services' }}>
  <div class="center stack" data-gap="xl">
    <EsaPageHeader title={PAGE_TITLE} lede={INTRO_PARAGRAPH} />

    <PsInfoWebServicesCatalog services={WEB_SERVICES} />
  </div>
</PsInfoAppShell>
