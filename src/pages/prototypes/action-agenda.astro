---
// Action Agenda — the real 2026–2030 Action Agenda Explorer landing page
// (actionagenda.pugetsoundinfo.wa.gov/2026-2030). Directed reproduction: same
// 4 sections, same order, same copy as the source, elevated with our
// components. Per-topic Strategies/Actions/Commitments/Overview text lives on
// each Topic's own /2026-2030/Topic/{id}/Overview subpage — a different URL,
// out of scope here — so unlike an earlier draft of this page, no per-topic
// detail, stat band, or category grouping renders on this landing page; see
// src/data/contracts/action-agenda.md for the full sourcing notes.
import PsInfoAppShell from '../../layouts/PsInfoAppShell.astro';
import PsInfoPhotoHeader from '../../components/psinfo/PsInfoPhotoHeader.astro';
import PsInfoSectionTitle from '../../components/psinfo/PsInfoSectionTitle.astro';
import PsInfoActionAgendaProse from '../../components/psinfo/PsInfoActionAgendaProse.astro';
import PsInfoActionAgendaTopicGrid from '../../components/psinfo/PsInfoActionAgendaTopicGrid.astro';
import EsaFilterContainer from '@esa/ecology/esa-filter-container.astro';
import EsaFilterClearButton from '@esa/ecology/esa-filter-clear-button.astro';
import EsaButton from '@esa/ecology/esa-button.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import {
  HEADER_TITLE, HEADER_IMAGE,
  SECTION_TITLE, INTRO_PARAGRAPHS,
  FILTERS, VITAL_SIGN_OPTIONS, TOPICS,
  EXPLORER_DESCRIPTION, EXPLORER_CTA,
} from '../../data/pages/action-agenda';

const ARROW = '<path d="M7 7h10v10"/><path d="M7 17 17 7"/>';
const vitalSignOptionsPayload = JSON.stringify(VITAL_SIGN_OPTIONS);
---
<!-- manifest:
  layout: PsInfoAppShell (active Plans > Action Agenda Explorer) > center+stack spine
  sections:
    - page header      -> psinfo-photo-header (photo band)
    - topics intro      -> psinfo-section-title + psinfo-action-agenda-prose
    - filter controls   -> esa-filter-container(esa-text-field + esa-select + esa-filter-clear-button) + no-results message
    - topic grid (26)   -> psinfo-action-agenda-topic-grid
    - explorer band       -> psinfo-action-agenda-prose + esa-button (external CTA)
-->
<PsInfoAppShell title="Action Agenda — Puget Sound Info" active={{ moduleId: 'plans', leafId: 'aa-explorer' }}>
  <div class="center stack" data-gap="xl">
    <PsInfoPhotoHeader
      size="band"
      image={HEADER_IMAGE}
      focus="50% 32%"
      title={HEADER_TITLE}
    />

    <div class="stack" data-gap="md" id="topics">
      <PsInfoSectionTitle title={SECTION_TITLE} />
      <PsInfoActionAgendaProse paragraphs={INTRO_PARAGRAPHS} />

      <EsaFilterContainer>
        <esa-text-field
          label={FILTERS.keywordLabel}
          size="sm"
        ></esa-text-field>
        <esa-select
          id="aa-vitalsign-select"
          label={FILTERS.vitalSignLabel}
          size="sm"
        ></esa-select>
        <EsaFilterClearButton label={FILTERS.clearLabel} />
      </EsaFilterContainer>
      <script type="application/json" id="aa-vitalsign-options" set:html={vitalSignOptionsPayload}></script>
      <p class="aa-noresults" hidden>{FILTERS.noResultsMessage}</p>

      <PsInfoActionAgendaTopicGrid topics={TOPICS} />
    </div>

    <div class="stack" data-gap="md" id="explorer">
      <PsInfoActionAgendaProse paragraphs={[EXPLORER_DESCRIPTION]} />
      <EsaButton href={EXPLORER_CTA.href} target="_blank" rel="noopener">
        {EXPLORER_CTA.label}
        <EsaIcon name="arrow-up-right" size="xs" paths={ARROW} />
      </EsaButton>
    </div>
  </div>
</PsInfoAppShell>

<script>
  import '@esa/ecology/esa-text-field';
  import '@esa/ecology/esa-select';

  const select = document.getElementById('aa-vitalsign-select') as (HTMLElement & { options?: unknown }) | null;
  const optionsEl = document.getElementById('aa-vitalsign-options');
  if (select && optionsEl?.textContent) {
    select.options = JSON.parse(optionsEl.textContent);
  }
</script>
