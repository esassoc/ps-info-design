---
// NEP Atlas — About (/Home/About, fetched 2026-07-22). Prod's About is one
// continuous article under the page title — no in-page H2s — so this page
// stays h1-only (photo header renders the one H1), which is a valid heading
// order. Photo trio sits between paragraph 1 and paragraph 2, matching
// prod's own inline float placement. See src/data/pages/nep-atlas.ts
// (ABOUT_PAGE, ABOUT_PHOTOS) and src/data/contracts/nep-atlas.md for full
// sourcing notes.
import PsInfoAppShell from '../../../layouts/PsInfoAppShell.astro';
import PsInfoPhotoHeader from '../../../components/psinfo/PsInfoPhotoHeader.astro';
import PsInfoNepAtlasNav from '../../../components/psinfo/PsInfoNepAtlasNav.astro';
import PsInfoNepAtlasNarrative from '../../../components/psinfo/PsInfoNepAtlasNarrative.astro';
import PsInfoAboutPhotoTrio from '../../../components/psinfo/PsInfoAboutPhotoTrio.astro';
import { HERO_TITLE, WELCOME_PHOTO, ABOUT_PAGE, ABOUT_PHOTOS } from '../../../data/pages/nep-atlas';
---
<!-- manifest:
  layout: PsInfoAppShell (active Implementation and Funding > NEP Atlas) > center+stack spine
  sections:
    - page header + band nav -> psinfo-photo-header (photo band, current=about) + psinfo-nep-atlas-nav
    - about narrative (intro) -> psinfo-nep-atlas-narrative (block 1: verbatim EPA/Action Agenda/Implementation Strategies/local plans paragraph)
    - photo trio              -> psinfo-about-photo-trio (3 real prod photos, source alt="")
    - about narrative (rest)  -> psinfo-nep-atlas-narrative (blocks 2-4: funding recipients intro + 7-item list + closing link)
-->
<PsInfoAppShell title="About — NEP Atlas — Puget Sound Info" active={{ moduleId: 'implementation', leafId: 'nep-atlas' }}>
  <div class="center stack" data-gap="xl">
    <PsInfoPhotoHeader
      size="band"
      image={WELCOME_PHOTO.image}
      focus="50% 35%"
      eyebrow={HERO_TITLE}
      title={ABOUT_PAGE.title}
    >
      <PsInfoNepAtlasNav slot="band" current="about" />
    </PsInfoPhotoHeader>

    <div class="stack" data-gap="lg" id="about">
      <PsInfoNepAtlasNarrative blocks={[ABOUT_PAGE.blocks[0]]} />
      <PsInfoAboutPhotoTrio photos={ABOUT_PHOTOS} />
      <PsInfoNepAtlasNarrative blocks={ABOUT_PAGE.blocks.slice(1)} />
    </div>
  </div>
</PsInfoAppShell>
