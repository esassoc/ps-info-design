---
// PsInfoVsGoalIntro — a goal page's statement block: the bold navy "Our goal
// is…" statement then the narrative paragraph, both verbatim from the source
// (VitalSignGoal/Detail/N). The goal's NAME and PHOTOGRAPH now live in the
// page's standard photo hero (PsInfoPhotoHeader renders the H1; the source's
// inline photo is the hero image) — a deliberate divergence from the source's
// in-body title block, standardizing the hero/h1 + band sub-nav pattern
// across home, Action Agenda, Vital Signs, and the goal pages.
//
// bcn-lego-checked: checked esa-page-header (title/lede header — this block
// has no title; its statement must render BOLDER and LARGER than the
// narrative, a two-tier prose hierarchy no lego models). Type tokens only;
// psinfo-vs-goal-intro is the reusable home.
interface Props {
  statement: string;
  narrative: string;
}
const { statement, narrative } = Astro.props;
---
<section class="goalintro" aria-label="Goal statement">
  <p class="goalintro__statement">{statement}</p>
  <p class="goalintro__narrative">{narrative}</p>
</section>

<style>
  .goalintro { display: flex; flex-direction: column; gap: var(--spacing-300); }
  .goalintro__statement {
    margin: 0;
    font-size: 1.375rem; font-weight: var(--font-weight-bold);
    color: var(--ps-info-blue-800); line-height: 1.35;
  }
  .goalintro__narrative {
    margin: 0;
    font-size: var(--ps-info-text-body); color: var(--color-text-primary); line-height: 1.6;
  }
</style>
