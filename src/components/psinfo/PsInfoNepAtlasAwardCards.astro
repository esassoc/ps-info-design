---
// PsInfoNepAtlasAwardCards — the complete 14-row NEP Awards roster (from
// Award/Index + Award/IndexGridJsonData; see src/data/pages/nep-atlas for
// sourcing). Each award funds a slice of the 1,614 NEP activities; five are
// retired per the source's own intro copy — flagged with a quiet neutral
// badge, never a colored border. Every card links out to the live
// Award/Detail page.
//
// bcn-lego-checked: no esa- lego renders this award/grant-card shape
// (name+retired badge+description+reporting leads+dollar figure); checked
// Beacon (no matching grant-card pattern). esa-card (outlined) is the reused
// surface, esa-badge is the reused primitive for the retired flag — same
// "quiet badge, no colored edge" rule as PsInfoStatusBadge.
import EsaCard from '@esa/ecology/esa-card.astro';
import EsaBadge from '@esa/ecology/esa-badge.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import type { AtlasAward } from '../../data/pages/nep-atlas';

interface Props {
  awards: AtlasAward[];
}
const { awards } = Astro.props;

const ARROW = '<path d="M7 7h10v10"/><path d="M7 17 17 7"/>';
const money = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD', maximumFractionDigits: 0 });
---
<div class="awards">
  {awards.map((award) => (
    <EsaCard variant="outlined">
      <div class="award">
        <div class="award__head">
          <a href={award.href} target="_blank" rel="noopener" class="award__name">
            {award.name}
            <EsaIcon name="arrow-up-right" size="xs" paths={ARROW} />
          </a>
          {award.retired && <EsaBadge value="Retired" variant="secondary" size="sm" />}
        </div>

        <div class="award__amount">{money.format(award.nepInvestment)}</div>

        <p class="award__desc">{award.description}</p>

        {award.reportingLeads && (
          <p class="award__leads"><span>Reporting leads:</span> {award.reportingLeads}</p>
        )}
      </div>
    </EsaCard>
  ))}
</div>

<style>
  .awards {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-400);
  }
  .award { display: flex; flex-direction: column; gap: var(--spacing-250); }

  .award__head { display: flex; align-items: flex-start; justify-content: space-between; gap: var(--spacing-250); }
  .award__name {
    flex: 1 1 auto; min-width: 0;
    font-size: 1.0625rem; font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary); text-decoration: none; line-height: 1.35;
  }
  .award__name:hover { color: var(--color-primary); }
  .award__name:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .award__name :global(.esa-icon) { color: var(--color-text-muted); margin-left: 2px; vertical-align: baseline; }
  .award__head :global(.esa-badge) { flex: none; }

  .award__amount {
    font-family: var(--font-display); font-size: 1.375rem; font-weight: var(--font-weight-semibold);
    color: var(--color-secondary-strong); font-variant-numeric: tabular-nums;
  }

  .award__desc { margin: 0; font-size: var(--ps-info-text-body); line-height: 1.6; color: var(--color-text-primary); }

  .award__leads {
    margin: 0; padding-top: var(--spacing-250); border-top: 1px solid var(--color-border-light);
    font-size: var(--ps-info-text-meta); color: var(--color-text-muted); line-height: 1.5;
  }
  .award__leads span { color: var(--color-text-tertiary); }
</style>
