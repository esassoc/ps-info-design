---
// PsInfoIndicatorsBoard — the 86-row indicator listing. Grouped by Vital Sign
// for the 70 Vital Sign Indicators (23 groups); the same component renders a
// single flat section for the 16 Progress Indicators, which have no Vital
// Sign to group by (pass one section with no heading). Modeled directly on
// PsInfoStrategyBoard's Topic -> Strategy board: neutral card rows, no
// colored left borders. There is no status column on the index — status only
// exists per-indicator on its own Detail page (see PsInfoIndicatorsBasics).
//
// bcn-lego-checked: rows compose esa-pill for the topic/legacy-strategy tag
// chips and esa-icon for the org glyph + the external-link mark; no esa- lego
// renders a grouped, repeating indicator listing itself (esa-card's
// header/body doesn't fit a repeating row list), so the row/group frame is
// bespoke structure — the same shape already established by
// PsInfoStrategyBoard. Checked Beacon: no matching grouped-listing pattern
// either. psinfo-indicators-board is the reusable home for both the grouped
// and flat listing shape.
import EsaIcon from '@esa/ecology/esa-icon.astro';
import EsaPill from '@esa/ecology/esa-pill.astro';
import { withBase } from '../../lib/base';
import type { IndicatorRow, IndicatorTag } from '../../data/pages/indicators';

export interface IndicatorBoardSection {
  /** Vital Sign name; omit for a flat (ungrouped) listing. */
  heading?: string;
  indicators: IndicatorRow[];
}
interface Props {
  sections: IndicatorBoardSection[];
  /** The one indicator that routes internally to its built detail page. */
  exemplarId: number;
  exemplarRoute: string;
}
const { sections, exemplarId, exemplarRoute } = Astro.props;

const ARROW = '<path d="M7 7h10v10"/><path d="M7 17 17 7"/>';
const BUILDING = '<rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M16 10h.01"/>';

// Source duplicates a strategy tag within a single row (e.g. the same 2022
// strategy listed 2-3x) — dedupe by name for display; everything else stays verbatim.
function dedupe(tags: IndicatorTag[]): IndicatorTag[] {
  const seen = new Set<string>();
  return tags.filter((t) => {
    if (seen.has(t.name)) return false;
    seen.add(t.name);
    return true;
  });
}
---
<div class="board">
  {sections.map((group) => (
    <div class="group">
      {group.heading && (
        <div class="group__head">
          <h3 class="group__name">{group.heading}</h3>
          <span class="group__count">{group.indicators.length} indicator{group.indicators.length === 1 ? '' : 's'}</span>
        </div>
      )}
      <ul class="rows" role="list">
        {group.indicators.map((row) => {
          const isExemplar = row.id === exemplarId;
          const legacy = dedupe(row.strategies2022);
          return (
            <li class="row">
              <div class="row__head">
                {isExemplar ? (
                  <a class="row__name" href={withBase(exemplarRoute)}>{row.name}</a>
                ) : (
                  <a class="row__name" href={row.detailUrl} target="_blank" rel="noopener">
                    {row.name}
                    <EsaIcon name="arrow-up-right" size="xs" paths={ARROW} />
                  </a>
                )}
                {row.org && row.orgHref ? (
                  <a class="row__org" href={row.orgHref} target="_blank" rel="noopener">
                    <EsaIcon name="building" size="xs" paths={BUILDING} />
                    {row.org}
                    <EsaIcon name="arrow-up-right" size="xs" paths={ARROW} />
                  </a>
                ) : row.org ? (
                  <span class="row__org row__org--plain">
                    <EsaIcon name="building" size="xs" paths={BUILDING} />
                    {row.org}
                  </span>
                ) : null}
              </div>
              {row.topics.length > 0 && (
                <div class="row__tags">
                  {row.topics.map((t) => <EsaPill label={t.name} size="xs" removable={false} />)}
                </div>
              )}
              {legacy.length > 0 && (
                <div class="row__tags">
                  <span class="row__tags-label">2022 strategies</span>
                  {legacy.map((t) => <EsaPill label={t.name} size="xs" variant="warning" removable={false} />)}
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </div>
  ))}
</div>

<style>
  .board { display: flex; flex-direction: column; gap: var(--spacing-500); }

  .group__head { display: flex; align-items: baseline; gap: var(--spacing-250); margin-bottom: var(--spacing-250); }
  .group__name { margin: 0; font-family: var(--font-display); font-size: 1.0625rem; font-weight: var(--font-weight-semibold); color: var(--color-text-primary); }
  .group__count { font-size: var(--ps-info-text-meta); color: var(--color-text-muted); white-space: nowrap; }

  .rows { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-200); }
  .row {
    display: flex; flex-direction: column; gap: var(--spacing-200);
    padding: var(--spacing-300) var(--spacing-400);
    background: var(--color-surface); border: 1px solid var(--color-border); border-radius: var(--radius-100);
  }

  .row__head { display: flex; align-items: baseline; flex-wrap: wrap; gap: var(--spacing-300); }
  .row__name {
    font-size: var(--ps-info-text-body); font-weight: var(--font-weight-medium);
    color: var(--color-text-primary); text-decoration: none;
  }
  .row__name:hover { color: var(--color-primary); text-decoration: underline; }
  .row__name:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .row__name :global(.esa-icon) { color: var(--color-text-muted); margin-left: 2px; vertical-align: -1px; }

  .row__org {
    display: inline-flex; align-items: center; gap: var(--spacing-100);
    font-size: var(--ps-info-text-meta-lg); color: var(--color-text-muted); text-decoration: none;
  }
  .row__org--plain { cursor: default; }
  a.row__org:hover { color: var(--color-primary); }
  a.row__org:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .row__org :global(.esa-icon) { color: var(--color-text-muted); }

  .row__tags { display: flex; flex-wrap: wrap; align-items: center; gap: var(--spacing-150); }
  .row__tags-label { font-size: var(--ps-info-text-meta); color: var(--color-text-muted); }

  @media (max-width: 640px) {
    .row__head { flex-direction: column; align-items: flex-start; gap: var(--spacing-150); }
  }
</style>
