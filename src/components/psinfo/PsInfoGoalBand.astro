---
// PsInfoGoalBand — the five statutory recovery goals as quiet identity tiles.
// The live homepage renders these as saturated color blocks; here the goal hue
// is a single dot mark over the goal name on a neutral tile (color lives in
// content, chrome stays neutral), each linking to its Vital Signs goal page.
// Names wrap balanced so two-line labels never strand an orphan.
//
// bcn-lego-checked: checked esa-card (a header/body content card — too heavy
// for a compact link tile), esa-pill / esa-badge (status chips, not nav
// tiles); nothing fits a goal-identity tile. Token-driven; psinfo-goal-band
// is the reusable home.
interface GoalItem {
  label: string;
  /** Key of the --ps-info-goal-* hue token (the prod Vital Signs goal colors). */
  hue: 'population' | 'quality' | 'species' | 'habitat' | 'water';
  href?: string;
}
interface Props {
  goals: readonly GoalItem[];
}
const { goals } = Astro.props;
---
<ul class="goalband" role="list">
  {goals.map((g) => (
    <li class="goalband__cell">
      <a class="goal" href={g.href} style={`--goal-hue: var(--ps-info-goal-${g.hue})`}>
        <span class="goal__dot" aria-hidden="true"></span>
        <span class="goal__name">{g.label}</span>
      </a>
    </li>
  ))}
</ul>

<style>
  .goalband {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: var(--spacing-400);
  }
  .goalband__cell { display: flex; }
  .goal {
    display: flex; flex-direction: column; gap: var(--spacing-250);
    flex: 1;
    padding: var(--spacing-400);
    background: var(--color-surface);
    border: 1px solid var(--color-border); border-radius: var(--radius-100);
    text-decoration: none;
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }
  .goal:hover {
    border-color: color-mix(in srgb, var(--goal-hue) 50%, var(--color-border));
    box-shadow: 0 2px 10px rgba(16, 42, 67, 0.08);
  }
  .goal:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .goal__dot { flex: none; width: 12px; height: 12px; border-radius: 50%; background: var(--goal-hue); }
  .goal__name {
    font-size: 1rem; font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary); line-height: 1.35;
    text-wrap: balance;
  }
</style>
