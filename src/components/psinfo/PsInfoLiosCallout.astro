---
// PsInfoLiosCallout — "What makes an LIO?": a lead sentence, the six-role
// participant list, and a closing sentence, inside esa-alert-box's info
// variant (the exact lego for the source page's light-blue-tinted bordered
// callout box). Thin data-to-slot mapper — no bespoke box CSS, just the
// paragraph+list+paragraph structure the source content needs inside the
// lego's slot.
import EsaAlertBox from '@esa/ecology/esa-alert-box.astro';

interface Props {
  title: string;
  lead: string;
  items: string[];
  closing: string;
}
const { title, lead, items, closing } = Astro.props;
---
<EsaAlertBox variant="info" title={title}>
  <p class="lios-callout__p">{lead}</p>
  <ul class="lios-callout__list" role="list">
    {items.map((item) => (
      <li>{item}</li>
    ))}
  </ul>
  <p class="lios-callout__p lios-callout__p--closing">{closing}</p>
</EsaAlertBox>

<style>
  .lios-callout__p {
    margin: 0 0 var(--spacing-200) 0;
    font-size: var(--ps-info-text-body);
    line-height: 1.6;
  }
  .lios-callout__p--closing { margin-bottom: 0; }
  .lios-callout__list {
    margin: 0 0 var(--spacing-300) 0;
    padding-left: var(--spacing-500);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-100);
    font-size: var(--ps-info-text-body);
    line-height: 1.5;
  }
</style>
