---
// PsInfoActionAgendaRefreshProse — verbatim body copy from the real 2026–2030
// Action Agenda Explorer / About pages: plain paragraphs, plus optional
// labeled subsections (e.g. "Foundations of Puget Sound Recovery" vs. "The
// Recovery Plan") with their own body paragraph and an optional list (the
// Recovery Plan's four themes). Same card treatment as PsInfoAboutNarrative
// so prose reads consistently across the site, without inheriting that
// component's inline-link-segment machinery this page's content doesn't need.
//
// bcn-lego-checked: no esa- lego renders ordered prose paragraphs plus
// labeled subsections with an optional list; checked Beacon (no matching
// narrative-body pattern). esa-card (outlined) is the reused surface, same as
// PsInfoAboutNarrative on the About page.
import EsaCard from '@esa/ecology/esa-card.astro';

export interface ProseSubsection {
  label: string;
  body: string;
  items?: string[];
}
interface Props {
  paragraphs?: string[];
  subsections?: ProseSubsection[];
}
const { paragraphs = [], subsections = [] } = Astro.props;
---
<EsaCard variant="outlined">
  <div class="prose">
    {paragraphs.map((p) => (
      <p class="prose__p">{p}</p>
    ))}
    {subsections.map((s) => (
      <div class="prose__section">
        <h3 class="prose__label">{s.label}</h3>
        <p class="prose__p">{s.body}</p>
        {s.items && s.items.length > 0 && (
          <ul class="prose__list" role="list">
            {s.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        )}
      </div>
    ))}
  </div>
</EsaCard>

<style>
  .prose { display: flex; flex-direction: column; gap: var(--spacing-400); }
  .prose__p {
    margin: 0; font-size: var(--ps-info-text-body); line-height: 1.65;
    color: var(--color-text-primary); max-width: 74ch;
  }
  .prose__section { display: flex; flex-direction: column; gap: var(--spacing-200); }
  .prose__label {
    margin: 0; font-family: var(--font-display); font-size: 1.0625rem;
    font-weight: var(--font-weight-semibold); color: var(--color-text-primary);
  }
  .prose__list {
    margin: 0; padding: 0; list-style: none;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: var(--spacing-200);
  }
  .prose__list li {
    padding: var(--spacing-250) var(--spacing-300);
    background: var(--color-surface-sunken); border-radius: var(--radius-100);
    font-size: var(--ps-info-text-meta-lg); font-weight: var(--font-weight-medium);
    color: var(--color-text-primary); line-height: 1.4;
  }
</style>
