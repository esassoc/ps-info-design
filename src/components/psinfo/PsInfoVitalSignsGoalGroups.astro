---
// PsInfoVitalSignsGoalGroups — the Vital Signs home page's interactive wheel
// graphic, reproduced as a readable list: all 23 Vital Signs grouped under
// their 5 recovery goals, in the wheel's own order. Vital Sign names ONLY —
// no indicator lists, no per-goal/per-Vital-Sign counts. The source wheel
// carries no numeric text anywhere; indicators appear one level deeper, on
// each goal's own Detail/N page (out of scope here).
//
// bcn-lego-checked: checked PsInfoGoalsVitalSignList (Goals unit) — it nests
// a per-indicator Progress/Target-Status badge tree under every Vital Sign,
// the wrong shape for this name-only wheel; checked PsInfoGoalBand (goal
// tiles only, no Vital Sign children) and PsInfoGoalPanel (one status badge
// per Vital Sign, still the wrong shape); checked esa-card/esa-collapsible —
// neither renders a group heading + flat link list. EsaCard (outlined) is
// reused as each group's surface; only the heading + flat vital-sign link
// list is this component's own. psinfo-vital-signs-goal-groups is the
// reusable home.
import EsaCard from '@esa/ecology/esa-card.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import { withBase } from '../../lib/base';
import type { GoalDetail } from '../../data/pages/goals';

interface Props {
  goals: GoalDetail[];
}
const { goals } = Astro.props;

// Two of this goal's Vital Signs get their own built page from the sibling
// vital-sign-details unit; route to those instead of the live (out-of-scope)
// VitalSign/Detail page. Same mapping the Goals unit's own list uses.
const INTERNAL_ROUTE: Record<string, string> = {
  Salmon: '/prototypes/vital-signs/chinook-salmon',
  Orcas: '/prototypes/vital-signs/orcas',
};

const ARROW = '<path d="M7 7h10v10"/><path d="M7 17 17 7"/>';
---
<ul class="goalgroups" role="list">
  {goals.map((goal) => (
    <li class="goalgroups__cell">
      <EsaCard variant="outlined">
        <div class="group__head cluster" data-gap="xs">
          <span class="group__hue" style={`background:var(${goal.hueVar})`} aria-hidden="true"></span>
          <a class="group__name" href={withBase(`/prototypes/goals/${goal.slug}`)}>{goal.name}</a>
        </div>
        <ul class="group__list" role="list">
          {goal.vitalSigns.map((vs) => {
            const internalRoute = INTERNAL_ROUTE[vs.name];
            return (
              <li>
                {internalRoute ? (
                  <a class="group__vs" href={withBase(internalRoute)}>{vs.name}</a>
                ) : (
                  <a class="group__vs" href={vs.href} target="_blank" rel="noopener">
                    {vs.name}
                    <EsaIcon name="arrow-up-right" size="xs" paths={ARROW} />
                  </a>
                )}
              </li>
            );
          })}
        </ul>
      </EsaCard>
    </li>
  ))}
</ul>

<style>
  .goalgroups {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--spacing-400);
  }
  .goalgroups__cell { display: flex; }
  .goalgroups__cell :global(.esa-card) { width: 100%; }

  .group__head {
    padding-bottom: var(--spacing-300); margin-bottom: var(--spacing-300);
    border-bottom: 1px solid var(--color-border-light);
  }
  .group__hue { flex: none; width: 12px; height: 12px; border-radius: 50%; }
  .group__name {
    font-family: var(--font-display); font-size: 1.0625rem; font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary); text-decoration: none;
  }
  .group__name:hover { color: var(--color-primary); text-decoration: underline; }
  .group__name:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }

  .group__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-200); }
  .group__vs {
    display: inline-flex; align-items: center; gap: var(--spacing-100);
    color: var(--color-text-link); text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 35%, transparent);
    font-size: var(--ps-info-text-body);
  }
  .group__vs:hover { text-decoration-color: currentColor; }
  .group__vs:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .group__vs :global(.esa-icon) { color: var(--color-text-muted); flex: none; }
</style>
