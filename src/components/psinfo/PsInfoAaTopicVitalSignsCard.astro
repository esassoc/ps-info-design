---
// PsInfoAaTopicVitalSignsCard — the Overview tab's right-floated "VITAL
// SIGNS" ribbon: prod's own card label text (a band label on a card, not an
// ornamental section heading) over a list of the Topic's related Vital Sign
// links.
//
// bcn-lego-checked: esa-card (outlined, no padding) is the container; the
// ribbon header band is prod's own card chrome — no esa- lego renders a
// tinted card-header band with an icon + label (esa-card's own header slot
// is a title/subtitle row, not a full-bleed tinted band). Checked Beacon (no
// matching pattern).
import EsaCard from '@esa/ecology/esa-card.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import { isExternalHref, EXTERNAL_LINK_ICON_PATHS } from '../../lib/psinfoExternalLink';

interface Props {
  label: string;
  links: { label: string; href: string }[];
}
const { label, links } = Astro.props;

// Lucide 'globe' — not in the shared registry yet, supplied as a paths fallback.
const GLOBE = '<circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/>';
---
<div class="aavs">
  <EsaCard variant="outlined" padding="none">
    <div class="aavs__band">
      <EsaIcon size="sm" paths={GLOBE} />
      <span>{label}</span>
    </div>
    <ul class="aavs__list" role="list">
      {links.map((link, i) => (
        <li>
          {i > 0 && <span class="aavs__sep" aria-hidden="true"> / </span>}
          <a
            class="aavs__link"
            href={link.href}
            {...(isExternalHref(link.href) ? { target: '_blank', rel: 'noopener' } : {})}
          >
            {link.label}
            {isExternalHref(link.href) && <EsaIcon name="external-link" size="xs" paths={EXTERNAL_LINK_ICON_PATHS} label="(external)" />}
          </a>
        </li>
      ))}
    </ul>
  </EsaCard>
</div>

<style>
  .aavs__band {
    display: flex; align-items: center; justify-content: center; gap: var(--spacing-200);
    padding: var(--spacing-300) var(--spacing-400);
    background: var(--ps-info-blue-800); color: #ffffff;
    letter-spacing: 0.08em;
    font-size: var(--ps-info-text-meta-lg); font-weight: var(--font-weight-semibold);
  }
  .aavs__band :global(.esa-icon) { color: #ffffff; }

  .aavs__list {
    list-style: none; margin: 0; padding: var(--spacing-300) var(--spacing-400);
    background: var(--ps-info-blue-100);
    display: flex; flex-wrap: wrap; justify-content: center; gap: var(--spacing-100) 0;
  }
  .aavs__list li { display: inline-flex; align-items: baseline; }
  /* Flex items trim edge whitespace — the breathing room around the slash
     must come from padding, not the text nodes. */
  .aavs__sep { color: var(--ps-info-blue-800); padding-inline: var(--spacing-150); }
  .aavs__link {
    display: inline-flex; align-items: baseline; gap: var(--spacing-100);
    font-size: 1rem; color: var(--color-text-link); text-decoration: underline; text-underline-offset: 3px; 
  }
  .aavs__link:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .aavs__link :global(.esa-icon) { color: var(--color-text-muted); }
</style>
