---
// PsInfoVsWheel — the Puget Sound Vital Signs wheel, rebuilt natively.
// The source home page ships this as a flat PNG (vitalsigns_wheel.png) with
// an <area> image map; this reproduces the same graphic in real HTML/CSS —
// a 7×7 tile ring (each tile a live Vital Sign link, positioned exactly per
// the source image map), goal-name bands on the four edges, and a center
// that is the source's own circle logo (segmented arc ring + two-tone disc
// wordmark, "v.3" tag included), cropped directly from vitalsigns_wheel.png
// so the ring art isn't duplicated by hand-built CSS. Tile colors sampled
// from the source PNG (see src/data/pages/vital-signs-module.ts).
//
// Each goal's edge band + tiles render inside a .wheel__group wrapper:
// display:contents on desktop (every piece still places itself in the ring
// grid), a real block on mobile — where the wheel UNROLLS into the center
// logo followed by five goal sections, each its band as a header over a
// two-column tile grid. Same DOM, same links, two geometries.
//
// bcn-lego-checked: no esa-* lego renders a tiled infographic (checked
// esa-card / esa-stat / layout primitives — a grid primitive can't carry the
// banded ring or donut); this is a faithful one-off reproduction of the
// site's own graphic, kept reusable behind the WHEEL_TILES data. Tile fills
// use the goals' theme tokens (the quality orange darkened 12% so white
// labels hold ≥4.5:1); band hues are the source PNG's own values, decorative
// only.
import { WHEEL_TILES, WHEEL_COLORS } from '../../data/pages/vital-signs-module';
import { WHEEL_CENTER_LOGO } from '../../data/pages/vital-signs';
import { withBase } from '../../lib/base';
import { isExternalHref } from '../../lib/psinfoExternalLink';

const TILE_FILL: Record<string, string> = {
  population: 'var(--ps-info-goal-population)',
  quality: 'color-mix(in srgb, var(--ps-info-goal-quality) 88%, #000000)',
  species: 'var(--ps-info-goal-species)',
  habitat: 'var(--ps-info-goal-habitat)',
  water: 'var(--ps-info-goal-water)',
};

// One entry per goal: its edge-band placement class on the ring, its band hue,
// and (via filter) its tiles. Array order is the mobile stacking order.
const GROUPS = [
  { goal: 'population', label: 'Healthy Human Population', edge: 'top', band: WHEEL_COLORS.band.population },
  { goal: 'quality', label: 'Vibrant Human Quality of Life', edge: 'right', band: WHEEL_COLORS.band.quality },
  { goal: 'species', label: 'Thriving Species & Food Web', edge: 'bottom', band: WHEEL_COLORS.band.species },
  { goal: 'habitat', label: 'Functioning Habitat', edge: 'left-bottom', band: WHEEL_COLORS.band.habitat },
  { goal: 'water', label: 'Healthy Water Quality', edge: 'left-top', band: WHEEL_COLORS.band.water },
];
---
<div class="wheel" role="group" aria-label="Puget Sound Vital Signs by recovery goal">
  <span class="wheel__cornerband" style={`background:${WHEEL_COLORS.corner}`} aria-hidden="true"></span>
  <span class="wheel__corner" aria-hidden="true">
    <img src={withBase('/psp-mark.png')} alt="" width="44" height="44" />
  </span>

  <div class="wheel__center">
    <img
      class="wheel__logo"
      src={withBase(WHEEL_CENTER_LOGO.src)}
      alt={WHEEL_CENTER_LOGO.alt}
      width={WHEEL_CENTER_LOGO.width}
      height={WHEEL_CENTER_LOGO.height}
    />
  </div>

  {GROUPS.map((g) => (
    <div class="wheel__group">
      <span class:list={['wheel__band', `wheel__band--${g.edge}`]} style={`background:${g.band}`}>{g.label}</span>
      {WHEEL_TILES.filter((t) => t.goal === g.goal).map((t) => {
        const style = `grid-row:${t.row + 1};grid-column:${t.col + 1};background:${TILE_FILL[t.goal]}`;
        return t.link.route ? (
          <a class="wheel__tile" style={style} href={withBase(t.link.route)}>{t.link.label}</a>
        ) : isExternalHref(t.link.externalHref) ? (
          <a class="wheel__tile" style={style} href={t.link.externalHref} target="_blank" rel="noopener">{t.link.label}</a>
        ) : (
          <a class="wheel__tile" style={style} href={t.link.externalHref}>{t.link.label}</a>
        );
      })}
    </div>
  ))}
</div>

<style>
  .wheel {
    --gap: 4px;
    display: grid;
    grid-template-columns: 52px repeat(7, 1fr) 52px;
    grid-template-rows: 52px repeat(7, 1fr) 52px;
    gap: var(--gap);
    aspect-ratio: 1 / 1;
    max-width: 820px;
    margin-inline: auto;
    width: 100%;
  }

  /* Desktop: the wrapper dissolves — band + tiles are direct ring-grid items. */
  .wheel__group { display: contents; }

  .wheel__band {
    display: flex; align-items: center; justify-content: center;
    color: #ffffff; font-weight: var(--font-weight-bold);
    font-size: clamp(0.8125rem, 1.6vw, 1.0625rem);
    text-transform: uppercase; letter-spacing: 0.14em; text-align: center;
  }
  .wheel__band--top { grid-row: 1; grid-column: 2 / 8; }
  .wheel__band--bottom { grid-row: 9; grid-column: 2 / 10; }
  .wheel__band--right { grid-row: 3 / 9; grid-column: 9; writing-mode: vertical-rl; }
  .wheel__band--left-top { grid-row: 1 / 5; grid-column: 1; writing-mode: vertical-rl; transform: rotate(180deg); }
  .wheel__band--left-bottom { grid-row: 5 / 10; grid-column: 1; writing-mode: vertical-rl; transform: rotate(180deg); }

  .wheel__cornerband { grid-row: 1 / 3; grid-column: 8 / 10; margin: 0 0 calc(var(--gap) * -1) calc(var(--gap) * -1); }
  .wheel__corner {
    grid-row: 2; grid-column: 8;
    background: #77787b;
    display: flex; align-items: center; justify-content: center;
  }
  .wheel__corner img { width: 42%; height: auto; filter: grayscale(1) brightness(1.9) opacity(0.55); }

  .wheel__tile {
    display: flex; align-items: center; justify-content: center;
    padding: var(--spacing-150);
    color: #ffffff; text-align: center; text-decoration: none;
    font-size: clamp(0.8125rem, 1.5vw, 1rem);
    font-weight: var(--font-weight-bold); line-height: 1.2;
    overflow-wrap: break-word;
  }
  .wheel__tile:hover { filter: brightness(1.12); }
  .wheel__tile:focus-visible { outline: 3px solid var(--focus-ring-color); outline-offset: -3px; z-index: 1; }

  .wheel__center {
    grid-row: 3 / 8; grid-column: 3 / 8;
    position: relative;
    display: flex; align-items: center; justify-content: center;
  }
  .wheel__logo { width: 84%; height: auto; border-radius: 50%; }

  /* Mobile: the wheel unrolls. Center logo first, then each goal as its band
     header over a two-column tile grid — same pieces, same links, readable at
     phone widths instead of a shrunken ring. */
  @media (max-width: 640px) {
    .wheel {
      display: flex; flex-direction: column;
      gap: var(--spacing-400);
      aspect-ratio: auto;
      max-width: 480px;
    }
    .wheel__cornerband, .wheel__corner { display: none; }

    .wheel__center { padding: var(--spacing-200) 0 var(--spacing-100); }
    .wheel__logo { width: min(58%, 220px); }

    .wheel__group {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3px;
    }
    .wheel__band {
      /* The edge-placement classes (--top/--right/…) still set ring rows;
         pin the band to its group's first row. */
      grid-row: 1; grid-column: 1 / -1;
      writing-mode: horizontal-tb; transform: none;
      padding: var(--spacing-250) var(--spacing-300);
      font-size: 1rem; letter-spacing: 0.08em;
    }
    /* The ring placements are inline styles on each tile — flatten them back
       into flow for the stacked grid (!important is the only way past inline). */
    .wheel__group .wheel__tile {
      grid-area: auto !important;
      min-height: 56px;
    }
    /* Odd tile count: the orphan last tile spans the full row. (Band is child
       1, so an even :nth-child means an odd tile count.) */
    .wheel__group .wheel__tile:last-child:nth-child(even) { grid-column: 1 / -1 !important; }
  }
</style>
