---
// PsInfoPiTopicTree — the Progress Indicators Topic Detail page's Fancytree
// TOPIC > PROGRESS INDICATOR grid, reproduced in the house Fancytree
// adaptation (sibling of PsInfoVsFancyTree — that component is scoped to the
// Vital Signs unit's own header labels and icon set, so this is a new
// PsInfoPi* component copying its one-level `vitalSigns` branch): toolbar
// (Expand Level / Collapse Level buttons, labelled search input, clear
// button), header strip, framed list, toggle script, filter script. The PI
// icon set (public/photos/pi/icons/) differs from the Vital Signs icon set —
// "Limited Data" as a TARGET STATUS icon exists only here.
//
// bcn-lego-checked: checked esa-collapsible (single disclosure, no
// tree/column semantics) and esa-tab-layout/esa-filter-container (wrong
// shapes); the Fancytree table convention is the source site's own UI,
// reproduced per the house adaptation (PsInfoVsFancyTree); PsInfoPiTopicTree
// is the PI unit's reusable home.
import EsaIcon from '@esa/ecology/esa-icon.astro';
import { withBase } from '../../lib/base';
import { isExternalHref } from '../../lib/psinfoExternalLink';
import type { PiTopicTreeData, PiProgressLabel, PiTargetStatusLabel } from '../../data/pages/progress-indicators';

interface Props {
  tree: PiTopicTreeData;
  treeId?: string;
}
const { tree, treeId = 'pitree' } = Astro.props;

const PROGRESS_ICON: Record<PiProgressLabel, string> = {
  'Indicator To Be Developed': 'progress-status-tobedeveloped.png',
  'Getting Worse': 'progress-gettingworse.png',
};
const TARGET_ICON: Record<PiTargetStatusLabel, string> = { 'Limited Data': 'status-limiteddata.png' };

const PLUS = '<path d="M5 12h14"/><path d="M12 5v14"/>';
const MINUS = '<path d="M5 12h14"/>';
const uid = (...parts: (string | number)[]) =>
  [treeId, ...parts].join('-').toLowerCase().replace(/[^a-z0-9-]+/g, '');
const rootId = uid(tree.topic);
---
<div class="pittree" id={treeId} style="--frame: var(--ps-info-blue-800)">
  <div class="pittree__toolbar">
    <button type="button" class="pittree__lvlbtn" data-tree-expand>Expand Level</button>
    <button type="button" class="pittree__lvlbtn" data-tree-collapse>Collapse Level</button>
    <label class="pittree__searchwrap">
      <span class="sr-only">Search the indicator tree</span>
      <input class="pittree__search" type="search" placeholder="Search..." data-tree-search />
    </label>
    <button type="button" class="pittree__clear" data-tree-clear aria-label="Clear search">×</button>
  </div>

  <div class="pittree__head" aria-hidden="true">
    <span class="pittree__head-path">
      Topic <EsaIcon name="chevron-right" size="xs" paths='<path d="m9 18 6-6-6-6"/>' /> Progress Indicator
    </span>
    <span class="pittree__head-col">Indicator Progress</span>
    <span class="pittree__head-col">Target Status</span>
  </div>

  <ul class="pittree__l0" role="list">
    <li class="pittree__topic" data-tree-row data-level="0" data-text={tree.topic.toLowerCase()}>
      <div class="pittree__row">
        <button
          type="button"
          class="pittree__toggle"
          data-tree-toggle
          aria-expanded="true"
          aria-controls={rootId}
          aria-label={`Toggle ${tree.topic}`}
        >
          <EsaIcon name="tree-toggle" size="sm" paths={MINUS} />
        </button>
        <a class="pittree__link pittree__link--topic" href={withBase(tree.route)}>{tree.topic}</a>
      </div>
      <ul class="pittree__l1" role="list" id={rootId}>
        {tree.indicators.map((ind) => (
          <li data-tree-row data-level="1" data-text={ind.name.toLowerCase()}>
            <div class="pittree__row pittree__row--ind">
              <a
                class="pittree__link pittree__link--ind"
                href={ind.href}
                {...(isExternalHref(ind.href) ? { target: '_blank', rel: 'noopener' } : {})}
              >{ind.name}</a>
              <span class="pittree__cell">
                <img src={withBase(`/photos/pi/icons/${PROGRESS_ICON[ind.progress]}`)} alt={ind.progress} width="64" height="64" loading="lazy" />
              </span>
              <span class="pittree__cell">
                {ind.targetStatus && (
                  <img src={withBase(`/photos/pi/icons/${TARGET_ICON[ind.targetStatus]}`)} alt={ind.targetStatus} width="64" height="64" loading="lazy" />
                )}
              </span>
            </div>
          </li>
        ))}
      </ul>
    </li>
  </ul>
</div>

<script>
  const MINUS_D = 'M5 12h14';
  const PLUS_D2 = 'M12 5v14';

  document.querySelectorAll<HTMLElement>('.pittree').forEach((tree) => {
    const toggles = [...tree.querySelectorAll<HTMLButtonElement>('[data-tree-toggle]')];

    const setToggle = (btn: HTMLButtonElement, open: boolean) => {
      btn.setAttribute('aria-expanded', String(open));
      const target = document.getElementById(btn.getAttribute('aria-controls') || '');
      if (target) target.hidden = !open;
      const svg = btn.querySelector('svg');
      if (svg) {
        svg.innerHTML = open ? `<path d="${MINUS_D}"/>` : `<path d="${MINUS_D}"/><path d="${PLUS_D2}"/>`;
      }
    };

    toggles.forEach((btn) => {
      btn.addEventListener('click', () => setToggle(btn, btn.getAttribute('aria-expanded') !== 'true'));
    });

    const levelOf = (btn: HTMLButtonElement) =>
      Number(btn.closest<HTMLElement>('[data-tree-row]')?.dataset.level ?? 0);

    tree.querySelector('[data-tree-expand]')?.addEventListener('click', () => {
      const closed = toggles.filter((b) => b.getAttribute('aria-expanded') !== 'true');
      if (!closed.length) return;
      const min = Math.min(...closed.map(levelOf));
      closed.filter((b) => levelOf(b) === min).forEach((b) => setToggle(b, true));
    });

    tree.querySelector('[data-tree-collapse]')?.addEventListener('click', () => {
      const open = toggles.filter((b) => b.getAttribute('aria-expanded') === 'true');
      if (!open.length) return;
      const max = Math.max(...open.map(levelOf));
      open.filter((b) => levelOf(b) === max).forEach((b) => setToggle(b, false));
    });

    const rows = [...tree.querySelectorAll<HTMLElement>('[data-tree-row]')];
    const search = tree.querySelector<HTMLInputElement>('[data-tree-search]');
    const applyFilter = (q: string) => {
      const query = q.trim().toLowerCase();
      if (!query) {
        rows.forEach((r) => { r.style.display = ''; });
        return;
      }
      rows.forEach((r) => { r.style.display = 'none'; });
      rows.forEach((r) => {
        if (!(r.dataset.text || '').includes(query)) return;
        let node: HTMLElement | null = r;
        while (node && node !== tree) {
          if (node.matches('[data-tree-row]')) node.style.display = '';
          const list = node.parentElement?.closest<HTMLElement>('ul[hidden]');
          node = node.parentElement?.closest<HTMLElement>('[data-tree-row]') ?? null;
          if (list) list.hidden = false;
        }
        r.querySelectorAll<HTMLElement>('[data-tree-row]').forEach((child) => { child.style.display = ''; });
        r.querySelectorAll<HTMLElement>('ul[hidden]').forEach((ul) => { ul.hidden = false; });
        r.querySelectorAll<HTMLButtonElement>('[data-tree-toggle]').forEach((b) => b.setAttribute('aria-expanded', 'true'));
      });
      // sync toggle glyphs after force-expanding
      tree.querySelectorAll<HTMLButtonElement>('[data-tree-toggle]').forEach((b) => {
        const target = document.getElementById(b.getAttribute('aria-controls') || '');
        if (target && !target.hidden) {
          b.setAttribute('aria-expanded', 'true');
          const svg = b.querySelector('svg');
          if (svg) svg.innerHTML = `<path d="${MINUS_D}"/>`;
        }
      });
    };
    search?.addEventListener('input', () => applyFilter(search.value));
    tree.querySelector('[data-tree-clear]')?.addEventListener('click', () => {
      if (search) { search.value = ''; applyFilter(''); search.focus(); }
    });
  });
</script>

<style>
  .pittree { display: flex; flex-direction: column; gap: var(--spacing-200); }
  .sr-only {
    position: absolute; width: 1px; height: 1px; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap;
  }

  .pittree__toolbar { display: flex; align-items: center; gap: var(--spacing-200); flex-wrap: wrap; }
  .pittree__lvlbtn {
    padding: var(--spacing-200) var(--spacing-300);
    background: var(--ps-info-blue-800); color: #ffffff;
    border-radius: var(--radius-100);
    font-size: var(--ps-info-text-meta-lg); font-weight: var(--font-weight-semibold);
  }
  .pittree__lvlbtn:hover { background: var(--ps-info-blue-900); }
  .pittree__lvlbtn:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .pittree__searchwrap { display: inline-flex; }
  .pittree__search {
    height: 36px; width: 220px; padding: 0 var(--spacing-300);
    border: 1px solid var(--color-border-strong); border-radius: var(--radius-100);
    background: var(--color-surface); color: var(--color-text-primary);
    font-size: var(--ps-info-text-meta-lg); font-family: inherit;
  }
  .pittree__search:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 1px; }
  .pittree__clear {
    width: 28px; height: 28px; border-radius: var(--radius-100);
    background: var(--color-surface-sunken); color: var(--color-text-secondary);
    font-size: 1rem; line-height: 1;
  }
  .pittree__clear:hover { background: var(--color-border); }
  .pittree__clear:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }

  .pittree__head {
    display: grid; grid-template-columns: 1fr 110px 110px; gap: var(--spacing-300);
    align-items: end;
    padding: var(--spacing-300) var(--spacing-400);
    background: var(--color-surface-sunken);
    border-radius: var(--radius-100) var(--radius-100) 0 0;
    font-size: var(--ps-info-text-meta-lg); font-weight: var(--font-weight-semibold);
    color: var(--color-text-secondary); text-transform: uppercase; letter-spacing: 0.03em;
  }
  .pittree__head-path { display: inline-flex; align-items: center; gap: var(--spacing-100); }
  .pittree__head-path :global(.esa-icon) { color: var(--color-text-muted); }
  .pittree__head-col { text-align: center; }

  .pittree__l0 {
    list-style: none; margin: 0; padding: 0;
    border: 2px solid var(--frame); border-radius: 0 0 var(--radius-100) var(--radius-100);
    background: var(--color-surface);
  }
  .pittree__l1 { list-style: none; margin: 0; padding: 0; }

  .pittree__row {
    display: flex; align-items: center; gap: var(--spacing-250);
    padding: var(--spacing-250) var(--spacing-400);
    background: #eef4fa;
    border-top: 1px solid var(--color-border-light);
  }
  .pittree__topic:first-child > .pittree__row { border-top: 0; }
  .pittree__row--ind {
    display: grid; grid-template-columns: 1fr 110px 110px; gap: var(--spacing-300);
    align-items: center;
    padding-left: calc(var(--spacing-400) + 2.25rem);
    background: var(--color-surface);
  }

  .pittree__toggle {
    flex: none; display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; border-radius: var(--radius-100);
    color: var(--color-text-primary); background: transparent;
  }
  .pittree__toggle:hover { background: rgba(16, 42, 67, 0.08); }
  .pittree__toggle:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 1px; }

  .pittree__link {
    font-size: var(--ps-info-text-body); color: var(--color-text-link);
    text-decoration: underline; text-underline-offset: 3px;
  }
  .pittree__link:hover { color: var(--color-text-link-hover); }
  .pittree__link:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .pittree__link--topic { font-weight: var(--font-weight-semibold); }
  .pittree__cell { display: flex; justify-content: center; }
  .pittree__cell img { width: 64px; height: 64px; }

  @media (max-width: 720px) {
    .pittree__head { grid-template-columns: 1fr 72px 72px; }
    .pittree__row--ind { grid-template-columns: 1fr 72px 72px; padding-left: var(--spacing-500); }
    .pittree__cell img { width: 48px; height: 48px; }
  }
</style>
