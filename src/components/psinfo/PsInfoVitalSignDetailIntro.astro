---
// PsInfoVitalSignDetailIntro — the Vital Sign Detail page's overview block:
// the source's single intro paragraph on an outlined card. The source sets
// this prose beside the page's photograph; in the prototype's standard
// hero/h1 pattern that photograph IS the photo hero, so this block carries
// the prose alone, sitting beside the reference sidebar in the page's
// two-column top region.
//
// bcn-lego-checked: esa-card is the surface (variant="outlined", matching
// every other content card on this page); the paragraph is plain prose.
// psinfo-vital-sign-detail-intro is the reusable home for this unit's two
// pages (Salmon, Orcas).
import EsaCard from '@esa/ecology/esa-card.astro';

interface Props {
  intro: string;
}
const { intro } = Astro.props;
---
<EsaCard variant="outlined">
  <p class="intro__p">{intro}</p>
</EsaCard>

<style>
  .intro__p {
    margin: 0;
    font-size: var(--ps-info-text-body);
    color: var(--color-text-primary);
    line-height: 1.65;
  }
</style>
