---
// PsInfoIndicatorsDefinitions — the two Indicator Type definitions (Vital Sign
// Indicators / Progress Indicators) plus the closing paragraph, rendered as
// plain prose. Verbatim from the Indicator/Index page body: back-to-back <p>
// tags with no card surface — matched here (2026-07-22 re-audit corrected a
// prior build that wrapped these in EsaCard, duplicating the portal cards'
// logo+definition pairing below). The www source marks the terms <strong><u>
// WITHOUT linking them; here each term is a REAL link to its portal
// destination (revision direction 2026-07-23) — bold, link-colored, and
// underlined per the site-wide inline-content-link convention, so the
// underline now signals an actual hyperlink.
//
// bcn-lego-checked: bare prose paragraphs — the source renders these as
// plain <p> tags with no card surface, so esa-card is deliberately NOT used
// and no esa- lego exists for body prose; checked Beacon (no prose-block
// component). psinfo-indicators-definitions stays the reusable home.
import { withBase } from '../../lib/base';
import type { IndicatorTypeDefinition } from '../../data/pages/indicators';

interface Props {
  definitions: IndicatorTypeDefinition[];
  closing?: string;
}
const { definitions, closing } = Astro.props;
---
<div class="defs">
  {definitions.map((d) => (
    <p class="defs__p"><a class="defs__term" href={withBase(d.href)}><strong>{d.term}</strong></a>{' '}{d.definition}</p>
  ))}
  {closing && <p class="defs__p">{closing}</p>}
</div>

<style>
  /* bcn-lego-checked: see frontmatter comment — bare prose paragraphs, no card surface in the source. */
  .defs { display: flex; flex-direction: column; gap: var(--spacing-300); }
  .defs__p {
    margin: 0; font-size: var(--ps-info-text-body); line-height: 1.65;
    color: var(--color-text-secondary);
  }
  .defs__term {
    color: var(--color-text-link);
    text-decoration: underline; text-underline-offset: 3px;
  }
  .defs__term:hover { color: var(--color-text-link-hover); }
  .defs__term:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
</style>
