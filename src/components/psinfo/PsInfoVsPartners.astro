---
// PsInfoVsPartners — the Contributing Partners logo wall: real logo files in
// DOM order, rendered at a standardized bordered cell size instead of the
// sources' mixed-dimension originals. Each logo links to its organization
// page. Defaults to the Vital Signs module's PARTNER_LOGOS with its centered
// heading; other units pass their own `partners` (and `heading={null}` when
// the page's own section title carries the heading) — the PI Topic Detail
// page reuses this wall so Contributing Partners reads identically site-wide
// (revision direction 2026-07-23; it previously had a bare-logo grid of its
// own).
//
// bcn-lego-checked: checked esa-card / esa-avatar (content card / person
// avatar — not a logo wall); a normalized logo grid is this component's own
// single job. Logos carry their organization name as alt text.
import { PARTNER_LOGOS } from '../../data/pages/vital-signs-module';
import { withBase } from '../../lib/base';
import { isExternalHref } from '../../lib/psinfoExternalLink';

export interface PartnerLogo {
  name: string;
  image: string;
  href: string;
}
interface Props {
  /** null renders no heading (the page's own section title carries it). */
  heading?: string | null;
  partners?: PartnerLogo[];
}
const { heading = 'Contributing Partners', partners = PARTNER_LOGOS } = Astro.props;
---
<section class="partners" aria-label={heading ?? 'Contributing Partners'}>
  {heading && <h2 class="partners__heading">{heading}</h2>}
  <ul class="partners__grid" role="list">
    {partners.map((p) => (
      <li>
        <a class="partners__cell" href={p.href} {...(isExternalHref(p.href) ? { target: '_blank', rel: 'noopener' } : {})}>
          <img src={withBase(p.image)} alt={p.name} loading="lazy" />
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .partners { display: flex; flex-direction: column; gap: var(--spacing-500); }
  .partners__heading {
    margin: 0; text-align: center;
    font-family: var(--font-display);
    font-size: 1.5rem; font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary);
  }
  .partners__grid {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: var(--spacing-400);
  }
  .partners__cell {
    display: flex; align-items: center; justify-content: center;
    height: 120px; padding: var(--spacing-300);
    background: var(--color-surface);
    border: 1px solid var(--color-border-light); border-radius: var(--radius-100);
    transition: border-color 150ms ease, box-shadow 150ms ease;
  }
  .partners__cell:hover { border-color: var(--color-border-strong); box-shadow: 0 2px 10px rgba(16, 42, 67, 0.08); }
  .partners__cell:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .partners__cell img { max-width: 100%; max-height: 100%; width: auto; height: auto; object-fit: contain; }
</style>
