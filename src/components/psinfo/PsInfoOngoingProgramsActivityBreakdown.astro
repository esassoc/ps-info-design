---
// PsInfoOngoingProgramsActivityBreakdown — the "Program List" tab's own intro
// paragraph, followed by its "Ongoing Programs by Activity Type" breakdown:
// verbatim heading + intro sentence, the source's donut-chart percentages
// (48%/34%/18%, decoded from its decorative alt="" chart image) rendered
// natively via PsInfoStatBand instead of re-embedding the raster chart, and
// the source's own 3-sentence <ul><li> breakdown with its <strong> emphasis
// terms preserved in the same sentence position.
//
// bcn-lego-checked: no esa- lego renders a heading + intro + stat row + a
// semantic emphasis list as one section — esa-stat (via PsInfoStatBand) is
// reused inside, but the section frame itself is bespoke prose structure,
// the same shape already established by PsInfoIndicatorsDefinitions. Checked
// Beacon: no matching heading+stats+list pattern. This is the reusable home.
import PsInfoStatBand from './PsInfoStatBand.astro';
import type { ActivityTypeBreakdownItem, ActivityTypeStat } from '../../data/pages/ongoing-programs';

interface Props {
  listIntro: string;
  heading: string;
  intro: string;
  stats: ActivityTypeStat[];
  breakdown: ActivityTypeBreakdownItem[];
}
const { listIntro, heading, intro, stats, breakdown } = Astro.props;
---
<div class="breakdown">
  <p class="breakdown__list-intro">{listIntro}</p>

  <div class="breakdown__section">
    <h2 class="breakdown__heading">{heading}</h2>
    <p class="breakdown__intro">{intro}</p>
  </div>

  <PsInfoStatBand stats={stats} />

  <ul class="breakdown__list" role="list">
    {breakdown.map((item) => (
      <li class="breakdown__item">
        {item.before}<strong>{item.emphasis}</strong>{item.after}
      </li>
    ))}
  </ul>
</div>

<style>
  .breakdown { display: flex; flex-direction: column; gap: var(--spacing-400); }

  .breakdown__list-intro {
    margin: 0; font-size: var(--ps-info-text-body); line-height: 1.65;
    color: var(--color-text-primary); max-width: 74ch;
  }

  .breakdown__section { display: flex; flex-direction: column; gap: var(--spacing-150); }
  .breakdown__heading {
    margin: 0; font-family: var(--font-display);
    font-size: 1.25rem; font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary); letter-spacing: -0.01em;
  }
  .breakdown__intro {
    margin: 0; font-size: var(--ps-info-text-body); line-height: 1.65;
    color: var(--color-text-secondary); max-width: 74ch;
  }

  .breakdown__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: var(--spacing-250);
  }
  .breakdown__item {
    position: relative; padding-left: var(--spacing-400);
    font-size: var(--ps-info-text-body); line-height: 1.6;
    color: var(--color-text-secondary); max-width: 74ch;
  }
  .breakdown__item::before {
    content: ''; position: absolute; left: 0; top: 0.6em;
    width: 6px; height: 6px; border-radius: var(--radius-full, 9999px);
    background: var(--color-primary-border);
  }
  .breakdown__item strong { color: var(--color-text-primary); font-weight: var(--font-weight-semibold); }
</style>
