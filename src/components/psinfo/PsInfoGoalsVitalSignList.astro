---
// PsInfoGoalsVitalSignList — one goal's Vital Signs, each with its own
// per-indicator Indicator Progress + (where the source ties an indicator to a
// numeric target) Target Status badges. Real data from the page's embedded
// treeSources tree (src/data/pages/goals.ts) — not psinfo-domain.ts's
// invented rollup-status vocabulary.
//
// bcn-lego-checked: checked PsInfoGoalPanel (same module) — it renders ONE
// status badge per Vital Sign, rolled up via domain.ts's IndicatorStatus; this
// page needs a badge per INDICATOR using the real ProgressLabel/
// TargetStatusLabel vocabulary, so that component's shape doesn't fit. Checked
// esa-card/esa-collapsible — neither renders a two-level name+badge tree.
// EsaCard (outlined) is reused as the surface for each Vital Sign; esa-badge
// (via the same tone->variant map PsInfoStatusBadge uses) renders every
// status; only the name+badge row/list structure is this component's own.
import EsaCard from '@esa/ecology/esa-card.astro';
import EsaBadge from '@esa/ecology/esa-badge.astro';
import EsaIcon from '@esa/ecology/esa-icon.astro';
import { withBase } from '../../lib/base';
import { PROGRESS_TONE, TARGET_STATUS_TONE, type GoalVitalSign } from '../../data/pages/goals';

interface Props {
  vitalSigns: GoalVitalSign[];
  /** --ps-info-goal-* token name — the ONLY place this goal's hue shows on
   *  this list: a quiet dot beside each Vital Sign's name, never text color,
   *  never a surface fill. */
  hueVar: string;
}
const { vitalSigns, hueVar } = Astro.props;

// The source's two column headers ("Indicator Progress" / "Target Status")
// don't survive the table -> card-list transform as literal <th> text, but
// their DISTINCTION must: without a label, two adjacent badges read as one
// group. Sentence-case, meta-size labels (not the banned uppercase/
// letter-spaced section-label treatment) restore that distinction per-row.

// Two of this goal's Vital Signs get their own dedicated page from a sibling
// unit; everything else stays a link into the live (out-of-scope) VitalSign/
// Detail page. "Salmon" -> chinook-salmon because Chinook is the Vital Sign's
// own headline indicator on the live site — the sibling page's slug, not a
// verbatim Vital Sign name.
const INTERNAL_ROUTE: Record<string, string> = {
  Salmon: '/prototypes/vital-signs/chinook-salmon',
  Orcas: '/prototypes/vital-signs/orcas',
};

// Same tone->variant map PsInfoStatusBadge.astro uses, just against the real
// ProgressLabel/TargetStatusLabel vocabulary instead of domain.ts's.
const TONE_VARIANT: Record<string, 'success' | 'info' | 'secondary' | 'warning' | 'danger'> = {
  success: 'success',
  info: 'info',
  neutral: 'secondary',
  warning: 'warning',
  danger: 'danger',
};

const ARROW = '<path d="M7 7h10v10"/><path d="M7 17 17 7"/>';
---
<ul class="vslist" role="list">
  {vitalSigns.map((vs) => {
    const internalRoute = INTERNAL_ROUTE[vs.name];
    return (
      <li>
        <EsaCard variant="outlined">
          <div class="vs__head">
            <span class="cluster" data-gap="xs">
              <span class="vs__hue" style={`background:var(${hueVar})`} aria-hidden="true" />
              {internalRoute ? (
                <a class="vs__link" href={withBase(internalRoute)}>{vs.name}</a>
              ) : (
                <a class="vs__link" href={vs.href} target="_blank" rel="noopener">
                  {vs.name}
                  <EsaIcon name="arrow-up-right" size="xs" paths={ARROW} />
                </a>
              )}
            </span>
          </div>

          <ul class="indlist" role="list">
            {vs.indicators.map((ind) => (
              <li class="ind repel" data-gap="sm">
                <a class="ind__link" href={ind.href} target="_blank" rel="noopener">
                  {ind.name}
                  <EsaIcon name="arrow-up-right" size="xs" paths={ARROW} />
                </a>
                <span class="ind__badges cluster" data-gap="2xs">
                  <span class="ind__stat">
                    <span class="ind__stat-label">Progress</span>
                    <EsaBadge value={ind.progress} variant={TONE_VARIANT[PROGRESS_TONE[ind.progress]]} size="sm" />
                  </span>
                  {ind.targetStatus && (
                    <span class="ind__stat">
                      <span class="ind__stat-label">Target</span>
                      <EsaBadge value={ind.targetStatus} variant={TONE_VARIANT[TARGET_STATUS_TONE[ind.targetStatus]]} size="sm" />
                    </span>
                  )}
                </span>
              </li>
            ))}
          </ul>
        </EsaCard>
      </li>
    );
  })}
</ul>

<style>
  .vslist { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: var(--spacing-400); }

  .vs__head { padding-bottom: var(--spacing-300); margin-bottom: var(--spacing-300); border-bottom: 1px solid var(--color-border-light); }
  .vs__hue { display: inline-block; width: 10px; height: 10px; border-radius: 50%; flex: none; }
  .vs__link {
    display: inline-flex; align-items: center; gap: var(--spacing-100);
    font-family: var(--font-display); font-size: 1.0625rem; font-weight: var(--font-weight-semibold);
    color: var(--color-text-primary); text-decoration: none;
  }
  .vs__link:hover { color: var(--color-primary); text-decoration: underline; }
  .vs__link:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .vs__link :global(.esa-icon) { color: var(--color-text-muted); }

  .indlist { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; }
  .ind { padding: var(--spacing-250) 0; }
  .ind + .ind { border-top: 1px solid var(--color-border-light); }
  .ind__link {
    color: var(--color-text-link); text-decoration: underline;
    text-decoration-color: color-mix(in srgb, currentColor 35%, transparent);
    font-size: var(--ps-info-text-body); display: inline-flex; align-items: center; gap: var(--spacing-100);
  }
  .ind__link:hover { text-decoration-color: currentColor; }
  .ind__link:focus-visible { outline: 2px solid var(--focus-ring-color); outline-offset: 2px; }
  .ind__link :global(.esa-icon) { color: var(--color-text-muted); flex: none; }
  .ind__badges { flex: none; }
  .ind__stat { display: inline-flex; align-items: center; gap: var(--spacing-100); }
  .ind__stat-label { font-size: var(--ps-info-text-meta); color: var(--color-text-muted); white-space: nowrap; }
</style>
